---
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  href: string;
  title: string;
  icon?: any;
  eyebrow?: string;
  meta?: string;
  ctaLabel?: string;
}

const {
  href,
  title,
  icon: Icon,
  eyebrow,
  meta,
  ctaLabel = 'Learn More'
} = Astro.props as Props;
---

<a href={href} class="group block h-full">
  <article class="relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/50 hover:shadow-lg">
    <!-- Subtle top accent line -->
    <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary/60 via-accent/40 to-primary/60 opacity-0 transition-opacity duration-200 group-hover:opacity-100"></div>
    
    {Icon && (
      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary/15">
        <Icon class="h-6 w-6 text-primary" />
      </div>
    )}

    <h3 class="flex items-center gap-2 text-xl font-semibold text-foreground">
      {title}
      <ArrowRight class="h-4 w-4 opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100" />
    </h3>

    {eyebrow && (
      <p class="mt-2 text-sm text-muted-foreground">
        {eyebrow}
      </p>
    )}

    <p class="mt-3 flex-1 text-sm leading-relaxed text-muted-foreground">
      <slot />
    </p>

    {meta && (
      <p class="mt-3 text-xs text-muted-foreground">
        {meta}
      </p>
    )}

    {ctaLabel && (
      <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary">
        {ctaLabel}
        <ArrowRight class="h-3.5 w-3.5" />
      </span>
    )}
  </article>
</a>

