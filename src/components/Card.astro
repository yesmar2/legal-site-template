---
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  href: string;
  title: string;
  icon?: any;
  eyebrow?: string;
  meta?: string;
  ctaLabel?: string;
}

const {
  href,
  title,
  icon: Icon,
  eyebrow,
  meta,
  ctaLabel = 'Learn More'
} = Astro.props as Props;
---

<a href={href} class="group block h-full">
  <article class="relative flex h-full flex-col rounded-2xl border border-border bg-card p-8 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
    {Icon && (
      <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary/15">
        <Icon class="h-6 w-6 text-primary" />
      </div>
    )}

    <h3 class="flex items-center gap-2 text-lg font-semibold text-foreground">
      {title}
      <ArrowRight class="h-4 w-4 text-primary opacity-0 transition-all duration-200 group-hover:translate-x-0.5 group-hover:opacity-100" />
    </h3>

    {eyebrow && (
      <p class="mt-2 text-sm text-muted-foreground">
        {eyebrow}
      </p>
    )}

    <p class="mt-4 flex-1 text-sm leading-relaxed text-muted-foreground">
      <slot />
    </p>

    {meta && (
      <p class="mt-4 text-xs text-muted-foreground">
        {meta}
      </p>
    )}

    {ctaLabel && (
      <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-all duration-200 group-hover:gap-3">
        {ctaLabel}
        <ArrowRight class="h-4 w-4" />
      </span>
    )}
  </article>
</a>
