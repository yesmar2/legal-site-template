---
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  href: string;
  title: string;
  icon?: any;
  eyebrow?: string;
  meta?: string;
  ctaLabel?: string;
}

const {
  href,
  title,
  icon: Icon,
  eyebrow,
  meta,
  ctaLabel = 'Learn More'
} = Astro.props as Props;
---

<a href={href} class="group block h-full">
  <article class="relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5">
    <!-- Subtle gradient overlay on hover -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary/0 via-primary/0 to-primary/0 opacity-0 transition-opacity duration-300 group-hover:from-primary/3 group-hover:via-transparent group-hover:to-accent/3 group-hover:opacity-100" />
    
    {Icon && (
      <div class="relative mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 transition-all duration-300 group-hover:bg-primary/15 group-hover:shadow-lg group-hover:shadow-primary/10">
        <Icon class="h-7 w-7 text-primary" />
      </div>
    )}

    <h3 class="relative flex items-center gap-2 font-serif text-xl font-semibold text-foreground">
      {title}
      <ArrowRight class="h-4 w-4 text-primary opacity-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100" />
    </h3>

    {eyebrow && (
      <p class="relative mt-2 text-sm text-muted-foreground">
        {eyebrow}
      </p>
    )}

    <p class="relative mt-4 flex-1 text-base leading-relaxed text-muted-foreground">
      <slot />
    </p>

    {meta && (
      <p class="relative mt-4 text-xs text-muted-foreground">
        {meta}
      </p>
    )}

    {ctaLabel && (
      <span class="relative mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-all duration-300 group-hover:gap-3">
        {ctaLabel}
        <ArrowRight class="h-4 w-4" />
      </span>
    )}
  </article>
</a>
