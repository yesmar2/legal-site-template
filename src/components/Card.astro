---
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  href: string;
  title: string;
  icon?: any;
  eyebrow?: string;
  meta?: string;
  ctaLabel?: string;
}

const {
  href,
  title,
  icon: Icon,
  eyebrow,
  meta,
  ctaLabel = 'Learn More'
} = Astro.props as Props;
---

<a href={href} class="group block h-full">
  <article class="flex h-full flex-col border border-border bg-card p-8 transition-all duration-300 hover:border-foreground/20 hover:bg-muted/30">
    {Icon && (
      <div class="mb-6 flex h-12 w-12 items-center justify-center border border-border bg-background">
        <Icon class="h-5 w-5 text-foreground" />
      </div>
    )}

    <h3 class="flex items-center gap-2 font-serif text-xl text-foreground md:text-2xl">
      {title}
    </h3>

    {eyebrow && (
      <p class="mt-3 text-sm text-muted-foreground">
        {eyebrow}
      </p>
    )}

    <p class="mt-4 flex-1 text-base leading-relaxed text-muted-foreground">
      <slot />
    </p>

    {meta && (
      <p class="mt-4 text-xs uppercase tracking-wider text-muted-foreground/70">
        {meta}
      </p>
    )}

    {ctaLabel && (
      <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-foreground">
        {ctaLabel}
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </span>
    )}
  </article>
</a>
