---
import Shield from '@lucide/astro/icons/shield';
import Users from '@lucide/astro/icons/users';
import Clock from '@lucide/astro/icons/clock';
import Award from '@lucide/astro/icons/award';
import { site } from '../config/site';
---
<section class="bg-muted py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Why Choose {site.firmName}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">
        When your future is on the line, you need an attorney who will fight for you.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
          <Shield class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-foreground">{site.yearsExperience}+ Years Experience</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Decades of dedicated legal experience protecting clients in {site.location.city} and throughout {site.location.county}.
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
          <Users class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-foreground">Personalized Attention</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Every case receives individual attention. You work directly with your attorney, not a paralegal.
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
          <Clock class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-foreground">Available When You Need Us</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          We understand legal emergencies don't wait. Reach us when you need help most.
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
          <Award class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-4 text-lg font-semibold text-foreground">Proven Track Record</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          A history of favorable outcomes for clients facing criminal charges, injury claims, and family disputes.
        </p>
      </div>
    </div>
  </div>
</section>

