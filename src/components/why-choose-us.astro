---
import { site } from '../config/site';
---
<section class="bg-muted py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <!-- Section header -->
    <div class="max-w-2xl">
      <span class="text-sm uppercase tracking-widest text-muted-foreground">Why Choose Us</span>
      <h2 class="mt-2 font-serif text-4xl text-foreground md:text-5xl lg:text-6xl">
        When your future is on the line, you need an attorney who will fight for you.
      </h2>
    </div>

    <!-- Features grid -->
    <div class="mt-16 grid gap-px bg-border md:grid-cols-2 lg:grid-cols-4">
      <div class="bg-muted p-8 md:p-10">
        <div class="font-serif text-4xl text-foreground md:text-5xl">{site.yearsExperience}+</div>
        <h3 class="mt-4 text-lg font-medium text-foreground">Years Experience</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Decades of dedicated legal experience protecting clients in {site.location.city} and throughout {site.location.county}.
        </p>
      </div>

      <div class="bg-muted p-8 md:p-10">
        <div class="font-serif text-4xl text-foreground md:text-5xl">1:1</div>
        <h3 class="mt-4 text-lg font-medium text-foreground">Personalized Attention</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Every case receives individual attention. You work directly with your attorney, not a paralegal.
        </p>
      </div>

      <div class="bg-muted p-8 md:p-10">
        <div class="font-serif text-4xl text-foreground md:text-5xl">24/7</div>
        <h3 class="mt-4 text-lg font-medium text-foreground">Available When Needed</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          We understand legal emergencies don't wait. Reach us when you need help most.
        </p>
      </div>

      <div class="bg-muted p-8 md:p-10">
        <div class="font-serif text-4xl text-foreground md:text-5xl">100%</div>
        <h3 class="mt-4 text-lg font-medium text-foreground">Proven Track Record</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          A history of favorable outcomes for clients facing criminal charges, injury claims, and family disputes.
        </p>
      </div>
    </div>
  </div>
</section>
