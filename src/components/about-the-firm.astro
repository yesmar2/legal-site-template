---
import Shield from '@lucide/astro/icons/shield';
import Users from '@lucide/astro/icons/users';
import Clock from '@lucide/astro/icons/clock';
import Award from '@lucide/astro/icons/award';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
---
<section class="bg-muted/30 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary">Why Choose Us</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
        About Our Firm
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        {site.firmName} represents clients throughout {site.location.city} and {site.location.county}, providing counsel in matters that affect their families, futures, and livelihoods in local courts across {site.location.county}.
      </p>
      <a
        href="/about"
        class="group mt-6 inline-flex items-center justify-center gap-2 text-sm font-semibold text-primary transition-all duration-200 hover:gap-3"
      >
        Learn more about {site.firmName}
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div class="group rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary/15">
          <Shield class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-5 text-lg font-semibold text-foreground">
          {site.yearsExperience}+ Years Experience
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Decades of legal experience representing clients in {site.location.city} and throughout {site.location.county}.
        </p>
      </div>

      <div class="group rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary/15">
          <Users class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-5 text-lg font-semibold text-foreground">
          Personalized Attention
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Every case receives individual attention so clients work directly with their attorney from start to finish.
        </p>
      </div>

      <div class="group rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary/15">
          <Clock class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-5 text-lg font-semibold text-foreground">
          Local Court Knowledge
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Regularly appearing in courts across {site.location.county}, with insight into local procedures and expectations.
        </p>
      </div>

      <div class="group rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 transition-colors duration-200 group-hover:bg-primary/15">
          <Award class="h-7 w-7 text-primary" />
        </div>
        <h3 class="mt-5 text-lg font-semibold text-foreground">
          Consultations Available
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          {site.consultationText}s are available to help clients understand their options before making important decisions.
        </p>
      </div>
    </div>
  </div>
</section>
