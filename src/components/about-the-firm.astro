---
import Shield from '@lucide/astro/icons/shield';
import Users from '@lucide/astro/icons/users';
import Clock from '@lucide/astro/icons/clock';
import Award from '@lucide/astro/icons/award';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import CheckCircle from '@lucide/astro/icons/circle-check';
import { site } from '../config/site';
---
<section class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left side content -->
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary">Why Choose Us</p>
        <h2 class="text-pretty text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
          About Our Firm
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
          {site.firmName} represents clients in criminal defense, family law, and other legal matters throughout {{city}} and {site.location.county}, providing experienced counsel tailored to meet your legal needs. With over {site.yearsExperience} years of experience serving the local community, we're committed to achieving the best possible outcomes for our clients.</p>

        <!-- Feature list -->
        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
            <div>
              <p class="font-semibold text-foreground">20+ Years Experience</p>
              <p class="text-sm text-muted-foreground">Decades of legal experience serving {site.location.city} and surrounding areas.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
            <div>
              <p class="font-semibold text-foreground">Personalized Attention</p>
              <p class="text-sm text-muted-foreground">Each client receives individualized attention and customized legal strategies.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
            <div>
              <p class="font-semibold text-foreground">Local Court Knowledge</p>
              <p class="text-sm text-muted-foreground">Intimate knowledge of local court procedures and practices throughout {site.location.county}.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
            <div>
              <p class="font-semibold text-foreground">{site.consultationText}s Available</p>
              <p class="text-sm text-muted-foreground">{site.consultationText}s help potential clients understand options and determine next steps.</p>
            </div>
          </li>
        </ul>

        <a
          href="/about"
          class="mt-8 inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-primary-foreground shadow-sm transition-all hover:bg-primary/90"
        >
          Learn More About Us
          <ArrowRight class="h-4 w-4" />
        </a>
      </div>

      <!-- Right side - Stats grid -->
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all hover:border-primary/30 hover:shadow-md">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
            <Shield class="h-7 w-7 text-primary" />
          </div>
          <h3 class="text-lg font-semibold text-foreground">
            {site.yearsExperience}+ Years
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Of legal experience representing clients throughout {site.location.city}.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all hover:border-primary/30 hover:shadow-md">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
            <Users class="h-7 w-7 text-primary" />
          </div>
          <h3 class="text-lg font-semibold text-foreground">
            Personalized Attention
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Every case receives direct attention from your attorney from start to finish.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all hover:border-primary/30 hover:shadow-md">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
            <Clock class="h-7 w-7 text-primary" />
          </div>
          <h3 class="text-lg font-semibold text-foreground">
            Local Court Expertise
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            Deep knowledge of procedures and practices in courts throughout {site.location.county}.
          </p>
        </div>

        <div class="rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all hover:border-primary/30 hover:shadow-md">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10">
            <Award class="h-7 w-7 text-primary" />
          </div>
          <h3 class="text-lg font-semibold text-foreground">
            {site.consultationText}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            {site.consultationText}s help you understand your case and legal options.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
