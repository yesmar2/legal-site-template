---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
---
<section class="bg-muted py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">
      <!-- Left column - Main content -->
      <div>
        <span class="text-sm uppercase tracking-widest text-muted-foreground">About Our Firm</span>
        <h2 class="mt-4 font-serif text-4xl text-foreground md:text-5xl lg:text-6xl">
          Trusted legal counsel for over {site.yearsExperience} years.
        </h2>
        <p class="mt-8 text-lg leading-relaxed text-muted-foreground">
          {site.firmName} represents clients throughout {site.location.city} and {site.location.county}, 
          providing counsel in matters that affect their families, futures, and livelihoods in local courts across the region.
        </p>
        <a
          href="/about"
          class="group mt-8 inline-flex items-center gap-2 text-sm font-medium text-foreground"
        >
          Learn more about us
          <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
        </a>
      </div>

      <!-- Right column - Stats grid -->
      <div class="grid grid-cols-2 gap-px bg-border">
        <div class="bg-muted p-8">
          <div class="font-serif text-4xl text-foreground">{site.yearsExperience}+</div>
          <p class="mt-2 text-sm text-muted-foreground">Years of dedicated legal experience</p>
        </div>
        <div class="bg-muted p-8">
          <div class="font-serif text-4xl text-foreground">1:1</div>
          <p class="mt-2 text-sm text-muted-foreground">Personal attention on every case</p>
        </div>
        <div class="bg-muted p-8">
          <div class="font-serif text-4xl text-foreground">Local</div>
          <p class="mt-2 text-sm text-muted-foreground">Deep knowledge of area courts</p>
        </div>
        <div class="bg-muted p-8">
          <div class="font-serif text-4xl text-foreground">Free</div>
          <p class="mt-2 text-sm text-muted-foreground">Initial consultations available</p>
        </div>
      </div>
    </div>
  </div>
</section>
