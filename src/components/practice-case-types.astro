---
import Car from '@lucide/astro/icons/car';
import Pill from '@lucide/astro/icons/pill';
import Swords from '@lucide/astro/icons/swords';
import Home from '@lucide/astro/icons/house';
import ShoppingBag from '@lucide/astro/icons/shopping-bag';
import Award from '@lucide/astro/icons/award';
import Users from '@lucide/astro/icons/users';
import FileText from '@lucide/astro/icons/file-text';
import Building2 from '@lucide/astro/icons/building-2';
import { site } from '../config/site';
import { caseTypes } from '../data/caseTypes';

const iconMap = {
  car: Car,
  pill: Pill,
  swords: Swords,
  home: Home,
  'shopping-bag': ShoppingBag,
  award: Award,
  heart: Award,
  users: Users,
  'file-text': FileText,
  'building-2': Building2,
} as const;

const practice = Astro.props.practice as { slug: string; name: string };
const typesForPractice = caseTypes.filter((type) => type.practiceSlug === practice.slug);
---
{typesForPractice.length > 0 && (
  <section class="bg-muted py-20 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          Types of {practice.name} Cases We Handle
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">
          Our attorneys handle a wide range of {practice.name.toLowerCase()} matters in {site.location.city} and throughout {site.location.county}.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {typesForPractice.map((caseType) => {
          const Icon = iconMap[caseType.icon as keyof typeof iconMap];
          return (
            <article class="group relative overflow-hidden rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:shadow-lg">
              <header>
                <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
                  {Icon && <Icon class="h-6 w-6 text-primary" />}
                </div>
                <h3 class="text-xl font-semibold text-foreground">
                  {caseType.title}
                </h3>
              </header>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                {caseType.description}
              </p>
            </article>
          );
        })}
      </div>
    </div>
  </section>
)}

