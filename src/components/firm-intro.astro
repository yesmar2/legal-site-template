---
import { site } from '../config/site';
---
<section class="border-b border-border bg-background py-20 md:py-24">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
      About {site.firmName}
    </h2>

    <p class="mt-4 text-base leading-relaxed text-muted-foreground md:text-lg">
      {site.firmName} represents clients throughout {site.location.city} and {site.location.county} in criminal 
      defense, personal injury, family law, and real estate matters. Attorney Michael J. Anderson 
      has more than {site.yearsExperience} years of legal experience helping individuals navigate complex legal 
      issues in local courts.
    </p>

    <a 
      href="/about"
      class="mt-6 inline-flex items-center justify-center gap-2 rounded-md border border-input bg-background px-5 py-2.5 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-muted"
    >
      Learn More
      <span class="text-xs">→</span>
    </a>
  </div>
</section>

