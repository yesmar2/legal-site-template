---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
---
<section class="border-b border-border bg-background py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
      <div>
        <span class="text-sm uppercase tracking-widest text-muted-foreground">About the Firm</span>
        <h2 class="mt-4 font-serif text-4xl text-foreground md:text-5xl">
          Dedicated legal representation for over {site.yearsExperience} years.
        </h2>
      </div>
      <div class="flex flex-col justify-end">
        <p class="text-lg leading-relaxed text-muted-foreground">
          {site.firmName} represents clients throughout {site.location.city} and {site.location.county} in criminal 
          defense, personal injury, family law, and real estate matters. Our experienced attorneys 
          help individuals navigate complex legal issues in local courts.
        </p>
        <a 
          href="/about"
          class="group mt-8 inline-flex items-center gap-2 text-sm font-medium text-foreground"
        >
          Learn More About Us
          <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
        </a>
      </div>
    </div>
  </div>
</section>
