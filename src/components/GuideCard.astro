---
import BookOpen from '@lucide/astro/icons/book-open';
import { courts as allCourts } from '@/src/content/courts';
import { site } from '@/src/config/site';
import Card from '@/src/components/Card.astro';

interface GuideLike {
  slug: string;
  title: string;
  description: string;
  practiceArea?: string;
  courts?: string[];
  lastReviewed?: string;
}

interface Props {
  title?: string;
  description?: string;
  slug?: string;
  category?: string;
  practiceAreaSlug?: string;
  courts?: string[];
  lastReviewed?: string;
  guide?: GuideLike;
}

const props = Astro.props as Props;

const baseGuide = (props.guide ?? {}) as GuideLike;

const title = props.title ?? baseGuide.title;
const description = props.description ?? baseGuide.description;
const slug = props.slug ?? baseGuide.slug;
const practiceAreaSlug = props.practiceAreaSlug ?? baseGuide.practiceArea;
const courts = props.courts ?? baseGuide.courts;
const lastReviewed = props.lastReviewed ?? baseGuide.lastReviewed;
const category = props.category;

const primaryCourtSlug = Array.isArray(courts) && courts.length > 0 ? courts[0] : undefined;
const primaryCourt = primaryCourtSlug
  ? allCourts.find((court) => court.slug === primaryCourtSlug)
  : undefined;
---

<Card
  href={slug ? `/guides/${slug}` : '#'}
  title={title ?? ''}
  icon={BookOpen}
  eyebrow={category}
  meta={
    primaryCourt
      ? `${primaryCourt.name} • ${site.location.county} ${site.address.state}`
      : lastReviewed
        ? `Last Reviewed: ${lastReviewed}`
        : undefined
  }
  ctaLabel="Read Guide"
>
  {description}
</Card>
