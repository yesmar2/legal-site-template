---
import User from '@lucide/astro/icons/user';
import { site } from '../config/site';
import { attorneys } from '../data/attorneys';
---
<section class="bg-background py-24 md:py-32" id="attorney">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary">Our Team</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
        Our Attorneys
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        Meet the attorneys representing clients throughout {site.location.city} and {site.location.county}.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {attorneys.map((attorney) => (
        <div class="group rounded-2xl border border-border bg-card p-8 text-center shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
          <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-primary/10">
            <User class="h-10 w-10 text-primary" />
          </div>
          <h3 class="text-xl font-semibold text-foreground">{attorney.name}</h3>
          <p class="mt-1 text-sm font-medium text-primary">
            {attorney.title}
          </p>
          {typeof attorney.yearsExperience === 'number' && attorney.yearsExperience > 0 && (
            <p class="mt-2 text-xs font-medium uppercase tracking-wider text-muted-foreground">
              {attorney.yearsExperience}+ Years Experience
            </p>
          )}
          <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
            {attorney.focus}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
