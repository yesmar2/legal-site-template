---
import User from '@lucide/astro/icons/user';
import { site } from '../config/site';
import { attorneys } from '../data/attorneys';
---
<section class="bg-muted pt-10 pb-20 md:pt-14 md:pb-24" id="attorney">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Our Attorneys
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
        Meet the attorneys representing clients throughout {site.location.city} and {site.location.county}.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {attorneys.map((attorney) => (
        <a href={attorney.href} class="group">
          <div class="h-full rounded-2xl border border-border bg-card p-6 text-center shadow-sm transition-all duration-300 hover:border-primary/50 hover:shadow-lg">
            <div class="mx-auto mb-4 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-primary/20 to-accent/20">
              <User class="h-10 w-10 text-primary" />
            </div>
            <h3 class="text-xl font-semibold text-foreground">{attorney.name}</h3>
            <p class="mt-1 text-sm font-medium text-primary">
              {attorney.title}
            </p>
            <p class="mt-4 text-base leading-relaxed text-muted-foreground">
              {attorney.focus}
            </p>
            <span class="mt-6 inline-flex items-center justify-center gap-2 text-sm font-medium text-primary">
              View Profile
              <span class="text-xs transition-transform group-hover:translate-x-0.5">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

