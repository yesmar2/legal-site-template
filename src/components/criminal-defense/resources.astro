---
import { guides } from '@/src/content/guides';
import { courts } from '@/src/content/courts';
import GuideCard from '@/src/components/GuideCard.astro';
import CourtCard from '@/src/components/CourtCard.astro';
import { site } from '@/src/config/site';

const relatedGuides = guides.filter((guide) => guide.practiceArea === 'criminal-defense');
const relatedCourts = courts.filter((court) =>
  ['jamestown-city-court', 'dunkirk-city-court', 'chautauqua-county-court'].includes(court.slug)
);
---
<section class="py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
      Related Legal Guides
    </h2>
    <p class="mt-3 max-w-2xl text-muted-foreground">
      Learn more about criminal defense procedures and legal processes in {site.location.city} and throughout {site.location.county}.
    </p>

    {relatedGuides.length > 0 && (
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {relatedGuides.map((guide) => (
          <GuideCard
            title={guide.title}
            description={guide.description}
            slug={guide.slug}
            category="Criminal Defense"
            practiceAreaSlug={guide.practiceArea}
            courts={guide.courts}
            lastReviewed={guide.lastReviewed}
          />
        ))}
      </div>
    )}
  </div>
</section>


