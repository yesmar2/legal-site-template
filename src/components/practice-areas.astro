---
import Scale from '@lucide/astro/icons/scale';
import HeartPulse from '@lucide/astro/icons/heart-pulse';
import Heart from '@lucide/astro/icons/heart';
import Building2 from '@lucide/astro/icons/building-2';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
import { practiceAreas } from '../data/practiceAreas';
import { caseTypes } from '../data/caseTypes';
import Card from '@/src/components/Card.astro';

const iconMap = {
  'scale': Scale,
  'heart-pulse': HeartPulse,
  'heart': Heart,
  'building-2': Building2
} as const;
---
<section class="bg-background py-20 md:py-28" id="practice-areas">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Practice Areas
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
        Comprehensive legal services tailored to protect your rights and achieve the best possible outcome for your case.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2">
      {practiceAreas.map((area) => {
        const Icon = iconMap[area.icon as keyof typeof iconMap];
        const types = caseTypes.filter((type) =>
          Array.isArray(area.caseTypeIds) ? area.caseTypeIds.includes(type.id) : false
        );

        const eyebrow = types
          .slice(0, 3)
          .map((t) => t.title.replace('Defense', '').trim())
          .join(' • ');


        return (
          <Card
            href={area.href}
            title={area.name}
            icon={Icon}
            eyebrow={eyebrow}
            meta={`Serving ${site.location.city} & ${site.location.county}`}
            ctaLabel="Learn More"
          >
            {area.description}
          </Card>
        );
      })}
    </div>
  </div>
</section>
