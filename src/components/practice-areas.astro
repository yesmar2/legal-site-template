---
import { practiceAreas } from '@/src/content/practiceAreas';
import PracticeAreaCard from '@/src/components/PracticeAreaCard.astro';
---
<section class="bg-muted/50 py-20 md:py-28" id="practice-areas">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary">Our Services</p>
      <h2 class="text-pretty text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
        Comprehensive Legal Services
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
        Comprehensive legal services tailored to protect your rights and achieve the best possible outcome for your case.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {practiceAreas.map((practiceArea) => (
        <PracticeAreaCard practiceArea={practiceArea} variant="home" />
      ))}
    </div>
  </div>
</section>
