---
import Scale from '@lucide/astro/icons/scale';
import HeartPulse from '@lucide/astro/icons/heart-pulse';
import Heart from '@lucide/astro/icons/heart';
import Building2 from '@lucide/astro/icons/building-2';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
---
<section class="bg-background py-20 md:py-28" id="practice-areas">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Practice Areas
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
        Comprehensive legal services tailored to protect your rights and achieve the best possible outcome for your case.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2">
      <a href="/jamestown-criminal-defense-lawyer" class="group">
        <div class="h-full rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary/50 hover:shadow-lg">
          <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
            <Scale class="h-6 w-6 text-primary" />
          </div>
          <h3 class="flex items-center gap-2 text-xl font-semibold text-foreground">
            Criminal Defense
            <ArrowRight class="h-4 w-4 opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100" />
          </h3>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            Defense representation for DUI, assault, theft, and other criminal charges in {site.location.city} and {site.location.county}.
          </p>
        </div>
      </a>

      <a href="/jamestown-personal-injury-lawyer" class="group">
        <div class="h-full rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary/50 hover:shadow-lg">
          <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
            <HeartPulse class="h-6 w-6 text-primary" />
          </div>
          <h3 class="flex items-center gap-2 text-xl font-semibold text-foreground">
            Personal Injury
            <ArrowRight class="h-4 w-4 opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100" />
          </h3>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            Legal representation for injury victims involved in car accidents, slip and fall cases, and other negligence claims.
          </p>
        </div>
      </a>

      <a href="/jamestown-family-lawyer" class="group">
        <div class="h-full rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary/50 hover:shadow-lg">
          <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
            <Heart class="h-6 w-6 text-primary" />
          </div>
          <h3 class="flex items-center gap-2 text-xl font-semibold text-foreground">
            Family Law
            <ArrowRight class="h-4 w-4 opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100" />
          </h3>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            Guidance and representation for divorce, custody, and other family law matters.
          </p>
        </div>
      </a>

      <a href="/jamestown-real-estate-lawyer" class="group">
        <div class="h-full rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-primary/50 hover:shadow-lg">
          <div class="mb-2 flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
            <Building2 class="h-6 w-6 text-primary" />
          </div>
          <h3 class="flex items-center gap-2 text-xl font-semibold text-foreground">
            Real Estate Law
            <ArrowRight class="h-4 w-4 opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100" />
          </h3>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            Legal assistance with residential and commercial real estate transactions and property matters.
          </p>
        </div>
      </a>
    </div>
  </div>
</section>

