---
import { practiceAreas } from '@/src/content/practiceAreas';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Plus from '@lucide/astro/icons/plus';
---
<section class="bg-background py-24 md:py-32" id="practice-areas">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <!-- Section header -->
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="text-sm uppercase tracking-widest text-muted-foreground">What We Do</span>
        <h2 class="mt-2 font-serif text-4xl text-foreground md:text-5xl lg:text-6xl">
          Practice Areas
        </h2>
      </div>
      <a 
        href="/practice-areas" 
        class="group inline-flex items-center gap-2 text-sm font-medium text-foreground transition-opacity hover:opacity-70"
      >
        View All Areas
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </a>
    </div>

    <!-- Practice area list - accordion style -->
    <div class="mt-16 divide-y divide-border border-y border-border">
      {practiceAreas.map((practiceArea, index) => (
        <a 
          href={practiceArea.href ?? `/practice/${practiceArea.slug}`}
          class="group flex items-center justify-between py-6 md:py-8 transition-colors hover:bg-muted/50 -mx-4 px-4"
        >
          <div class="flex items-center gap-6 md:gap-12">
            <span class="font-mono text-sm text-muted-foreground">0{index + 1}</span>
            <h3 class="font-serif text-xl text-foreground md:text-2xl lg:text-3xl">{practiceArea.name}</h3>
          </div>
          <div class="flex items-center gap-4">
            <span class="hidden text-sm text-muted-foreground md:block max-w-xs truncate">
              {practiceArea.homeCardDescription || practiceArea.description}
            </span>
            <Plus class="h-5 w-5 text-foreground transition-transform group-hover:rotate-45" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
