---
import { practiceAreas } from '@/src/data/practiceAreas';
import PracticeAreaCard from '@/src/components/PracticeAreaCard.astro';
---
<section class="bg-background py-24 md:py-32" id="practice-areas">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary">Our Services</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
        Practice Areas
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        Comprehensive legal services tailored to protect your rights and achieve the best possible outcome for your case.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {practiceAreas.map((practiceArea) => (
        <PracticeAreaCard practiceArea={practiceArea} variant="home" />
      ))}
    </div>
  </div>
</section>
