---
import Building2 from '@lucide/astro/icons/building-2';
import { site } from '@/src/config/site';
import Card from '@/src/components/Card.astro';

type Variant = 'full' | 'summary' | 'home';

interface Props {
  court: {
    slug: string;
    name: string;
    location: {
      city: string;
      county?: string;
      state?: string;
    };
    description?: string;
    cardDescription?: string;
    homeCardDescription?: string;
  };
  variant?: Variant;
  ctaLabel?: string;
}

const { court, variant = 'summary', ctaLabel: ctaLabelOverride } = Astro.props as Props;

const city = court.location.city;
const county = court.location.county ?? site.location.county;
const state = court.location.state ?? site.address.state;
const fullDescription = court.cardDescription ?? court.description;
const homeDescription = court.homeCardDescription ?? fullDescription;
const href = `/courts/${court.slug}`;
const ctaLabel = ctaLabelOverride ?? (variant === 'full' ? 'View Court Details' : 'Learn More');
---

<Card
  href={href}
  title={court.name}
  icon={Building2}
  eyebrow={`${city}${county ? ` • ${county}` : ''}`}
  meta={variant === 'full' ? `${county} ${state}` : undefined}
  ctaLabel={ctaLabel}
>
  {variant === 'home' ? homeDescription : fullDescription}
</Card>

