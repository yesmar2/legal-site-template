---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
import { courts } from '../data/courts';
import CourtCard from '@/src/components/CourtCard.astro';
---
<section class="bg-muted py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <!-- Section header -->
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="text-sm uppercase tracking-widest text-muted-foreground">Local Courts</span>
        <h2 class="mt-2 font-serif text-4xl text-foreground md:text-5xl lg:text-6xl">
          Courts We Handle
        </h2>
      </div>
      <a 
        href="/courts" 
        class="group inline-flex items-center gap-2 text-sm font-medium text-foreground transition-opacity hover:opacity-70"
      >
        View All Courts
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </a>
    </div>

    <p class="mt-6 max-w-2xl text-muted-foreground">
      {site.copy.localCourtsLeadCityCounty
        .replace('{{city}}', site.location.city)
        .replace('{{county}}', site.location.county)}
    </p>

    <!-- Court cards -->
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {courts.map((court) => (
        <CourtCard court={court} variant="home" />
      ))}
    </div>

    <div class="mt-12">
      <a 
        href="/guides/criminal-case-process-new-york" 
        class="group inline-flex items-center gap-2 text-sm font-medium text-foreground"
      >
        Learn about the criminal case process
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </div>
</section>
