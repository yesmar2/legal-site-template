---
import Building2 from '@lucide/astro/icons/building-2';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
import { courts } from '../data/courts';
import CourtCard from '@/src/components/CourtCard.astro';
---
<section class="bg-muted pt-16 pb-8 md:pt-18 md:pb-10">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Local Courts We Handle
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
        {site.copy.localCourtsLeadCityCounty
          .replace('{{city}}', site.location.city)
          .replace('{{county}}', site.location.county)}
        Learn more about the courts where criminal and civil cases are handled.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {courts.map((court) => (
        <CourtCard court={court} variant="home" />
      ))}
    </div>

    <div class="mt-10 text-center">
      <a 
        href="/guides/criminal-case-process-new-york" 
        class="inline-flex items-center gap-1.5 text-sm text-primary hover:underline"
      >
        Learn more about how local courts handle criminal cases
        <ArrowRight class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</section>

