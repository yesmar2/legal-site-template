---
import Shield from '@lucide/astro/icons/shield';
import MapPin from '@lucide/astro/icons/map-pin';
import Clock from '@lucide/astro/icons/clock';
import Scale from '@lucide/astro/icons/scale';
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Check from '@lucide/astro/icons/check';
import Gavel from '@lucide/astro/icons/gavel';
import FileText from '@lucide/astro/icons/file-text';
import Star from '@lucide/astro/icons/star';
import { site } from '../config/site';
---
<section class="relative overflow-hidden bg-background pb-24 pt-16 md:pb-32 md:pt-20">
  <!-- Subtle background pattern -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute right-0 top-0 h-[700px] w-[700px] -translate-y-1/3 translate-x-1/3 rounded-full bg-primary/[0.03] blur-3xl" />
    <div class="absolute bottom-0 left-0 h-[500px] w-[500px] -translate-x-1/4 translate-y-1/4 rounded-full bg-primary/[0.02] blur-3xl" />
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-16 lg:grid-cols-2 lg:gap-20">
      <!-- Left Content -->
      <div class="max-w-xl">
        <!-- Eyebrow badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-4 py-1.5 text-sm text-muted-foreground">
          <span class="flex h-1.5 w-1.5 rounded-full bg-primary" />
          Serving {site.location.city} & {site.location.county}, {site.address.state}
        </div>

        <h1 class="text-balance text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-[3.5rem] lg:leading-[1.1]">
          {site.location.city}<br />
          <span class="text-primary">Criminal Defense</span><br />
          Lawyers
        </h1>

        <p class="mt-3 text-xl font-medium text-muted-foreground sm:text-2xl">
          {site.firmName}
        </p>

        <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
          At {site.firmName}, we represent clients throughout {site.location.city} and {site.location.county}, {site.address.state} in criminal defense, personal injury, family law, and real estate matters.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contact"
            class="group inline-flex h-12 items-center justify-center gap-2 rounded-xl bg-primary px-6 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/25 transition-all duration-200 hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/30"
          >
            <Calendar class="h-4 w-4" />
            Schedule {site.consultationText}
            <ArrowRight class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
            class="inline-flex h-12 items-center justify-center gap-2 rounded-xl border border-border bg-background px-6 text-sm font-semibold text-foreground transition-all duration-200 hover:bg-muted"
          >
            <Phone class="h-4 w-4 text-primary" />
            Call {site.phone}
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4">
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Check class="h-4 w-4 text-primary" />
            <span>{site.consultationText}</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Check class="h-4 w-4 text-primary" />
            <span>{site.yearsExperience}+ Years Experience</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <Check class="h-4 w-4 text-primary" />
            <span>Trial Proven</span>
          </div>
        </div>
      </div>

      <!-- Right Side - Visual Card Stack (like the inspiration) -->
      <div class="relative lg:pl-8">
        <!-- Main card with courthouse image -->
        <div class="relative">
          <div class="overflow-hidden rounded-2xl border border-border bg-card shadow-2xl shadow-foreground/5">
            <!-- Image area -->
            <div class="relative">
              <img 
                src="/courthouse-hero.jpg" 
                alt="Courthouse" 
                class="h-[280px] w-full object-cover sm:h-[320px]"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-foreground/50 via-transparent to-transparent" />
              
              <!-- Stats overlay on image -->
              <div class="absolute bottom-4 left-4 right-4 flex gap-3">
                <div class="flex items-center gap-2 rounded-lg bg-white/95 px-3 py-2 shadow-lg backdrop-blur-sm">
                  <div class="flex h-8 w-8 items-center justify-center rounded-md bg-primary">
                    <Shield class="h-4 w-4 text-primary-foreground" />
                  </div>
                  <div>
                    <p class="text-sm font-bold text-foreground">{site.yearsExperience}+</p>
                    <p class="text-[10px] text-muted-foreground">Years</p>
                  </div>
                </div>
                <div class="flex items-center gap-2 rounded-lg bg-white/95 px-3 py-2 shadow-lg backdrop-blur-sm">
                  <div class="flex h-8 w-8 items-center justify-center rounded-md bg-primary">
                    <MapPin class="h-4 w-4 text-primary-foreground" />
                  </div>
                  <div>
                    <p class="text-sm font-bold text-foreground">Local</p>
                    <p class="text-[10px] text-muted-foreground">{site.location.county}</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Card content area -->
            <div class="p-5">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-primary">Legal Services</p>
                  <h3 class="mt-1 text-lg font-semibold text-foreground">{site.firmName}</h3>
                  <p class="mt-1 text-sm text-muted-foreground">{site.location.city}, {site.address.state}</p>
                </div>
                <div class="flex gap-1">
                  {[...Array(5)].map(() => (
                    <Star class="h-4 w-4 fill-primary text-primary" />
                  ))}
                </div>
              </div>
              
              <!-- Service tags -->
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">Criminal Defense</span>
                <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">Personal Injury</span>
                <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">Family Law</span>
              </div>
            </div>
          </div>

          <!-- Floating card - top right -->
          <div class="absolute -right-2 -top-6 z-10 rounded-xl border border-border bg-card p-4 shadow-xl sm:-right-6 sm:-top-8">
            <div class="flex items-center gap-3">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10">
                <Gavel class="h-5 w-5 text-primary" />
              </div>
              <div>
                <p class="text-sm font-bold text-foreground">Trial Proven</p>
                <p class="text-xs text-muted-foreground">Courtroom Experience</p>
              </div>
            </div>
          </div>

          <!-- Floating card - bottom left -->
          <div class="absolute -bottom-6 -left-2 z-10 rounded-xl border border-border bg-card p-4 shadow-xl sm:-bottom-8 sm:-left-6">
            <div class="flex items-center gap-3">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10">
                <FileText class="h-5 w-5 text-primary" />
              </div>
              <div>
                <p class="text-sm font-bold text-foreground">{site.consultationText}</p>
                <p class="text-xs text-muted-foreground">Get Started Today</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
