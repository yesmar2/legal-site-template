---
import Shield from '@lucide/astro/icons/shield';
import MapPin from '@lucide/astro/icons/map-pin';
import Clock from '@lucide/astro/icons/clock';
import Scale from '@lucide/astro/icons/scale';
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Check from '@lucide/astro/icons/check';
import { site } from '../config/site';
---
<section class="relative overflow-hidden bg-background pb-20 pt-12 md:pb-28 md:pt-16">
  <!-- Subtle background elements -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute right-0 top-0 h-[600px] w-[600px] -translate-y-1/4 translate-x-1/4 rounded-full bg-primary/5 blur-3xl" />
    <div class="absolute bottom-0 left-0 h-[500px] w-[500px] -translate-x-1/4 translate-y-1/4 rounded-full bg-accent/5 blur-3xl" />
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left Content -->
      <div>
        <!-- Eyebrow badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-4 py-1.5 text-sm text-muted-foreground">
          <span class="flex h-1.5 w-1.5 rounded-full bg-primary" />
          Serving {site.location.city} & {site.location.county}, {site.address.state}
        </div>

        <h1 class="text-balance text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
          {site.location.city}<br />
          <span class="text-primary">Criminal Defense</span><br />
          Lawyers
        </h1>

        <p class="mt-2 text-xl font-medium text-muted-foreground sm:text-2xl">
          {site.firmName}
        </p>

        <p class="mt-6 max-w-lg text-lg leading-relaxed text-muted-foreground">
          At {site.firmName}, we represent clients throughout {site.location.city} and {site.location.county}, {site.address.state} in criminal defense, personal injury, family law, and real estate matters.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contact"
            class="group inline-flex h-12 items-center justify-center gap-2 rounded-xl bg-primary px-6 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-all duration-200 hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/30"
          >
            <Calendar class="h-4 w-4" />
            Schedule {site.consultationText}
            <ArrowRight class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
            class="inline-flex h-12 items-center justify-center gap-2 rounded-xl border border-border bg-background px-6 text-sm font-semibold text-foreground transition-all duration-200 hover:bg-muted"
          >
            <Phone class="h-4 w-4 text-primary" />
            Call {site.phone}
          </a>
        </div>
      </div>

      <!-- Right Side - Visual Card Element -->
      <div class="relative">
        <!-- Courthouse background image -->
        <div class="relative overflow-hidden rounded-2xl">
          <img 
            src="/courthouse-hero.jpg" 
            alt="Courthouse" 
            class="h-[400px] w-full object-cover lg:h-[480px]"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-foreground/60 via-foreground/20 to-transparent" />
          
          <!-- Overlay stats cards -->
          <div class="absolute bottom-6 left-6 right-6">
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-xl border border-white/10 bg-white/10 p-4 backdrop-blur-md">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary">
                    <Shield class="h-5 w-5 text-primary-foreground" />
                  </div>
                  <div>
                    <p class="text-xl font-bold text-white">{site.yearsExperience}+</p>
                    <p class="text-xs text-white/70">Years Experience</p>
                  </div>
                </div>
              </div>
              <div class="rounded-xl border border-white/10 bg-white/10 p-4 backdrop-blur-md">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary">
                    <MapPin class="h-5 w-5 text-primary-foreground" />
                  </div>
                  <div>
                    <p class="text-xl font-bold text-white">Local</p>
                    <p class="text-xs text-white/70">{site.location.county}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -right-4 -top-4 rounded-xl border border-border bg-background p-4 shadow-xl sm:-right-8">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10">
              <Clock class="h-5 w-5 text-primary" />
            </div>
            <div>
              <p class="text-sm font-bold text-foreground">Free</p>
              <p class="text-xs text-muted-foreground">Initial Consultation</p>
            </div>
          </div>
        </div>

        <!-- Floating badge bottom left -->
        <div class="absolute -bottom-4 -left-4 rounded-xl border border-border bg-background p-4 shadow-xl sm:-left-8">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10">
              <Scale class="h-5 w-5 text-primary" />
            </div>
            <div>
              <p class="text-sm font-bold text-foreground">Trial</p>
              <p class="text-xs text-muted-foreground">Proven Experience</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
