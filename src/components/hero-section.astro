---
import Shield from '@lucide/astro/icons/shield';
import MapPin from '@lucide/astro/icons/map-pin';
import Clock from '@lucide/astro/icons/clock';
import Scale from '@lucide/astro/icons/scale';
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import { site } from '../config/site';
---
<section class="relative isolate flex min-h-[85vh] max-h-screen items-center overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950">
  <!-- Decorative gradient orbs -->
  <div
    aria-hidden="true"
    class="absolute -top-40 left-1/2 -z-10 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/30 via-indigo-500/20 to-transparent blur-3xl" 
  />
  <div
    aria-hidden="true"
    class="absolute -bottom-20 right-0 -z-10 h-[400px] w-[400px] rounded-full bg-gradient-to-tl from-blue-600/20 via-cyan-500/10 to-transparent blur-3xl" 
  />
  <div
    aria-hidden="true"
    class="absolute bottom-0 left-0 -z-10 h-[300px] w-[300px] rounded-full bg-gradient-to-tr from-indigo-600/15 to-transparent blur-3xl" 
  />

  <!-- Subtle grid pattern -->
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px]" 
  />

  <div class="relative mx-auto flex w-full max-w-7xl flex-col px-6 py-12 lg:px-8 2xl:py-16">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Eyebrow badge -->
      <div class="mb-4 inline-flex items-center gap-2 rounded-modern border border-white/10 bg-white/5 px-4 py-1.5 text-sm text-slate-300 backdrop-blur-sm transition-smooth hover:border-white/20 hover:bg-white/10">
        <span class="flex h-2 w-2 rounded-full bg-emerald-400" />
        Serving {site.location.city} &amp; {site.location.county}
      </div>

      <h1 class="text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl xl:text-6xl 2xl:text-7xl">
        {site.firmName}
      </h1>
      <p class="mt-2 bg-gradient-to-r from-blue-400 via-cyan-300 to-blue-400 bg-clip-text text-lg font-medium text-transparent sm:text-xl lg:text-2xl 2xl:text-3xl">
        {site.tagline}
      </p>

      <p class="mx-auto mt-4 max-w-2xl text-pretty text-sm leading-relaxed text-slate-400 sm:text-base 2xl:text-lg">
        {site.firmName} represents clients throughout {site.location.city} and {site.location.county} in 
        criminal defense, personal injury, family law, and real estate matters.
      </p>

      <div class="mt-5 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4 2xl:mt-8 2xl:gap-5">
        <a
          href="/contact"
          class="group inline-flex h-12 items-center justify-center gap-3 rounded-modern bg-gradient-to-r from-blue-600 to-blue-500 px-6 text-sm font-medium text-white shadow-lg shadow-blue-500/25 transition-smooth hover:from-blue-500 hover:to-blue-400 hover:shadow-refined-lg hover:shadow-blue-500/30 2xl:h-14 2xl:px-8 2xl:text-base"
        >
          <Calendar class="h-5 w-5" />
          Schedule {site.consultationText}
          <span class="inline-block text-sm transition-smooth group-hover:translate-x-0.5">→</span>
        </a>
        <a href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}>
          <span 
            class="inline-flex h-12 items-center justify-center gap-3 rounded-modern border border-white/15 bg-white/5 px-6 text-sm font-medium text-white backdrop-blur-sm transition-smooth hover:border-white/25 hover:bg-white/10 2xl:h-14 2xl:px-8 2xl:text-base"
          >
            <Phone class="h-5 w-5" />
            Call {site.phone}
          </span>
        </a>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="mx-auto mt-10 max-w-3xl md:mt-12 2xl:mt-16">
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4 2xl:gap-5">
        <div class="group flex flex-col items-center gap-2 rounded-modern border border-white/10 bg-white/[0.03] px-5 py-4 text-center backdrop-blur-sm transition-smooth hover:border-blue-400/40 hover:bg-white/[0.06] 2xl:gap-3 2xl:px-8 2xl:py-6">
          <div class="flex h-12 w-12 items-center justify-center rounded-modern-sm bg-gradient-to-br from-blue-500/25 to-blue-600/20 ring-1 ring-white/15">
            <Shield class="h-6 w-6 text-blue-300" />
          </div>
          <span class="text-2xl font-semibold text-white 2xl:text-3xl">{site.yearsExperience}+</span>
          <span class="text-xs text-slate-400 2xl:text-sm">Years Experience</span>
        </div>
        <div class="group flex flex-col items-center gap-2 rounded-modern border border-white/10 bg-white/[0.03] px-5 py-4 text-center backdrop-blur-sm transition-smooth hover:border-emerald-400/40 hover:bg-white/[0.06] 2xl:gap-3 2xl:px-8 2xl:py-6">
          <div class="flex h-12 w-12 items-center justify-center rounded-modern-sm bg-gradient-to-br from-emerald-500/25 to-emerald-600/20 ring-1 ring-white/15">
            <MapPin class="h-6 w-6 text-emerald-300" />
          </div>
          <span class="text-2xl font-semibold text-white 2xl:text-3xl">Local</span>
          <span class="text-xs text-slate-400 2xl:text-sm">Chautauqua County</span>
        </div>
        <div class="group flex flex-col items-center gap-2 rounded-modern border border-white/10 bg-white/[0.03] px-5 py-4 text-center backdrop-blur-sm transition-smooth hover:border-cyan-400/40 hover:bg-white/[0.06] 2xl:gap-3 2xl:px-8 2xl:py-6">
          <div class="flex h-12 w-12 items-center justify-center rounded-modern-sm bg-gradient-to-br from-cyan-500/25 to-cyan-600/20 ring-1 ring-white/15">
            <Clock class="h-6 w-6 text-cyan-300" />
          </div>
          <span class="text-2xl font-semibold text-white 2xl:text-3xl">Free</span>
          <span class="text-xs text-slate-400 2xl:text-sm">Initial Consultation</span>
        </div>
        <div class="group flex flex-col items-center gap-2 rounded-modern border border-white/10 bg-white/[0.03] px-5 py-4 text-center backdrop-blur-sm transition-smooth hover:border-amber-400/40 hover:bg-white/[0.06] 2xl:gap-3 2xl:px-8 2xl:py-6">
          <div class="flex h-12 w-12 items-center justify-center rounded-modern-sm bg-gradient-to-br from-amber-500/25 to-amber-600/20 ring-1 ring-white/15">
            <Scale class="h-6 w-6 text-amber-300" />
          </div>
          <span class="text-2xl font-semibold text-white 2xl:text-3xl">Trial</span>
          <span class="text-xs text-slate-400 2xl:text-sm">Proven Experience</span>
        </div>
      </div>
    </div>
  </div>
</section>

