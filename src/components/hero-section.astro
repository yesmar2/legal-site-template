---
import Shield from '@lucide/astro/icons/shield';
import MapPin from '@lucide/astro/icons/map-pin';
import Clock from '@lucide/astro/icons/clock';
import Scale from '@lucide/astro/icons/scale';
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
---
<section class="relative overflow-hidden bg-background pb-16 pt-8 md:pb-24 md:pt-12">
  <!-- Subtle background elements -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-64 -top-64 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"
  />
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-32 -left-32 h-[400px] w-[400px] rounded-full bg-primary/5 blur-3xl"
  />

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left content -->
      <div>
        <!-- Eyebrow badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary">
          <span class="flex h-2 w-2 rounded-full bg-primary" />
          Serving {site.location.city} & {site.location.county}
        </div>

        <h1 class="text-balance text-5xl font-extrabold leading-tight tracking-tight text-foreground sm:text-6xl lg:text-7xl">
          {site.location.city} <span class="text-primary">Criminal Defense</span> Lawyers
        </h1>

        <p class="mt-4 text-lg font-semibold text-muted-foreground">
          {site.firmName}
        </p>

        <p class="mt-6 max-w-lg text-lg leading-relaxed text-muted-foreground">
          At {site.firmName}, we represent clients throughout {site.location.city} and {site.location.county}, providing counsel in matters that affect their families, futures, and livelihoods in criminal defense, personal injury, family law, and real estate matters.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contact"
            class="group inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3.5 text-base font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-all hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/25"
          >
            <Calendar class="h-5 w-5" />
            Schedule Your Consultation
          </a>
          <a
            href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-border bg-background px-6 py-3.5 text-base font-semibold text-foreground transition-all hover:border-primary/30 hover:bg-muted"
          >
            <Phone class="h-5 w-5 text-primary" />
            Call {site.phone}
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-10 flex flex-wrap items-center gap-6 border-t border-border pt-8">
          <p class="text-sm text-muted-foreground">Trusted by clients across:</p>
          <div class="flex flex-wrap gap-3">
            {site.serviceAreas.slice(0, 3).map((area) => (
              <span class="text-sm font-medium text-foreground">{area}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Right side - Stats cards with glass effect -->
      <div class="relative">
        <!-- Decorative gradient behind cards -->
        <div
          aria-hidden="true"
          class="absolute inset-0 rounded-3xl bg-gradient-to-br from-muted via-background to-muted"
        />

        <div class="relative grid gap-4 sm:grid-cols-2">
          <!-- Stats card 1 -->
          <div class="rounded-2xl border border-border bg-card/80 p-6 shadow-sm backdrop-blur-sm transition-all hover:border-primary/30 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
              <Shield class="h-6 w-6 text-primary" />
            </div>
            <p class="text-3xl font-bold text-foreground">{site.yearsExperience}+</p>
            <p class="mt-1 text-sm text-muted-foreground">Years of Experience</p>
          </div>

          <!-- Stats card 2 -->
          <div class="rounded-2xl border border-border bg-card/80 p-6 shadow-sm backdrop-blur-sm transition-all hover:border-primary/30 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
              <MapPin class="h-6 w-6 text-primary" />
            </div>
            <p class="text-3xl font-bold text-foreground">Local</p>
            <p class="mt-1 text-sm text-muted-foreground">{site.location.county}</p>
          </div>

          <!-- Stats card 3 -->
          <div class="rounded-2xl border border-border bg-card/80 p-6 shadow-sm backdrop-blur-sm transition-all hover:border-primary/30 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
              <Clock class="h-6 w-6 text-primary" />
            </div>
            <p class="text-3xl font-bold text-foreground">Free</p>
            <p class="mt-1 text-sm text-muted-foreground">Initial Consultation</p>
          </div>

          <!-- Stats card 4 -->
          <div class="rounded-2xl border border-border bg-card/80 p-6 shadow-sm backdrop-blur-sm transition-all hover:border-primary/30 hover:shadow-md">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
              <Scale class="h-6 w-6 text-primary" />
            </div>
            <p class="text-3xl font-bold text-foreground">Trial</p>
            <p class="mt-1 text-sm text-muted-foreground">Proven Experience</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
