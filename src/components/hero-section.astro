---
import Shield from '@lucide/astro/icons/shield';
import MapPin from '@lucide/astro/icons/map-pin';
import Clock from '@lucide/astro/icons/clock';
import Scale from '@lucide/astro/icons/scale';
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
---
<section class="relative isolate overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 pb-32 pt-40 md:pb-40 md:pt-48 lg:pb-48 lg:pt-56">
  <!-- Decorative gradient orbs -->
  <div 
    aria-hidden="true"
    class="absolute -top-40 left-1/2 -z-10 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/30 via-indigo-500/20 to-transparent blur-3xl" 
  />
  <div 
    aria-hidden="true"
    class="absolute -bottom-20 right-0 -z-10 h-[400px] w-[400px] rounded-full bg-gradient-to-tl from-blue-600/20 via-cyan-500/10 to-transparent blur-3xl" 
  />
  <div 
    aria-hidden="true"
    class="absolute bottom-0 left-0 -z-10 h-[300px] w-[300px] rounded-full bg-gradient-to-tr from-indigo-600/15 to-transparent blur-3xl" 
  />

  <!-- Subtle grid pattern -->
  <div 
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px]" 
  />

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Eyebrow badge -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-sm text-slate-300 backdrop-blur-sm">
        <span class="flex h-2 w-2 rounded-full bg-emerald-400" />
        Serving Jamestown &amp; Chautauqua County
      </div>

      <h1 class="text-balance text-5xl font-semibold tracking-tight text-white sm:text-6xl md:text-7xl lg:text-8xl">
        Anderson Law
      </h1>
      <p class="mt-4 bg-gradient-to-r from-blue-400 via-cyan-300 to-blue-400 bg-clip-text text-2xl font-medium text-transparent sm:text-3xl md:text-4xl">
        Criminal Defense, Personal Injury &amp; Family Law
      </p>

      <p class="mx-auto mt-8 max-w-2xl text-pretty text-lg leading-relaxed text-slate-400 md:text-xl md:leading-relaxed">
        Anderson Law represents clients throughout Jamestown and Chautauqua County in 
        criminal defense, personal injury, family law, and real estate matters.
      </p>

      <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-5">
        <a
          href="/contact"
          class="group inline-flex h-14 items-center justify-center gap-3 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 px-8 text-base font-medium text-white shadow-lg shadow-blue-500/25 transition-all hover:from-blue-500 hover:to-blue-400 hover:shadow-xl hover:shadow-blue-500/30"
        >
          <Calendar class="h-5 w-5" />
          Schedule Free Consultation
          <span class="inline-block text-sm transition-transform group-hover:translate-x-0.5">→</span>
        </a>
        <a href="tel:+17165551234">
          <span 
            class="inline-flex h-14 items-center justify-center gap-3 rounded-full border border-white/15 bg-white/5 px-8 text-base font-medium text-white backdrop-blur-sm transition-all hover:border-white/25 hover:bg-white/10"
          >
            <Phone class="h-5 w-5" />
            Call (716) 555-1234
          </span>
        </a>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="mx-auto mt-20 max-w-3xl md:mt-24">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 sm:gap-5">
        <div class="group flex flex-col items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-8 py-6 backdrop-blur-sm transition-all hover:border-blue-400/40 hover:bg-white/[0.06]">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-blue-500/25 to-blue-600/20 ring-1 ring-white/15">
            <Shield class="h-6 w-6 text-blue-300" />
          </div>
          <span class="text-3xl font-semibold text-white">20+</span>
          <span class="text-sm text-slate-400">Years Experience</span>
        </div>
        <div class="group flex flex-col items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-8 py-6 backdrop-blur-sm transition-all hover:border-emerald-400/40 hover:bg-white/[0.06]">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-500/25 to-emerald-600/20 ring-1 ring-white/15">
            <MapPin class="h-6 w-6 text-emerald-300" />
          </div>
          <span class="text-3xl font-semibold text-white">Local</span>
          <span class="text-sm text-slate-400">Chautauqua County</span>
        </div>
        <div class="group flex flex-col items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-8 py-6 backdrop-blur-sm transition-all hover:border-cyan-400/40 hover:bg-white/[0.06]">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-500/25 to-cyan-600/20 ring-1 ring-white/15">
            <Clock class="h-6 w-6 text-cyan-300" />
          </div>
          <span class="text-3xl font-semibold text-white">Free</span>
          <span class="text-sm text-slate-400">Initial Consultation</span>
        </div>
        <div class="group flex flex-col items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-8 py-6 backdrop-blur-sm transition-all hover:border-amber-400/40 hover:bg-white/[0.06]">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-amber-500/25 to-amber-600/20 ring-1 ring-white/15">
            <Scale class="h-6 w-6 text-amber-300" />
          </div>
          <span class="text-3xl font-semibold text-white">Trial</span>
          <span class="text-sm text-slate-400">Proven Experience</span>
        </div>
      </div>
    </div>
  </div>
</section>

