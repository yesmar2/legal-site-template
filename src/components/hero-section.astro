---
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
---
<section class="relative min-h-[90vh] overflow-hidden bg-foreground">
  <!-- Video/Image background with overlay -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center opacity-40" />
    <div class="absolute inset-0 bg-foreground/60" />
  </div>

  <!-- Content -->
  <div class="relative z-10 flex min-h-[90vh] flex-col">
    <!-- Main hero content -->
    <div class="flex flex-1 flex-col justify-center px-6 py-24 md:px-12 lg:px-20">
      <div class="mx-auto w-full max-w-6xl">
        <!-- Location tag -->
        <div class="mb-8">
          <span class="inline-flex items-center gap-2 text-sm tracking-widest text-primary-foreground/60 uppercase">
            <span class="h-px w-8 bg-primary-foreground/30" />
            Serving {site.location.city} & {site.location.county}
          </span>
        </div>

        <!-- Main heading with serif font -->
        <h1 class="max-w-4xl font-serif text-4xl text-primary-foreground sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl">
          <span class="block">{site.firmName}</span>
        </h1>
        
        <p class="mt-4 max-w-xl text-lg text-primary-foreground/70 md:text-xl">
          {site.tagline}
        </p>

        <!-- CTA buttons -->
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href="/contact"
            class="group inline-flex items-center justify-center gap-3 bg-primary-foreground px-8 py-4 text-sm font-medium text-foreground transition-all hover:bg-primary-foreground/90"
          >
            <Calendar class="h-4 w-4" />
            Schedule {site.consultationText}
            <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a 
            href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
            class="inline-flex items-center justify-center gap-3 border border-primary-foreground/30 px-8 py-4 text-sm font-medium text-primary-foreground transition-all hover:border-primary-foreground/60 hover:bg-primary-foreground/5"
          >
            <Phone class="h-4 w-4" />
            {site.phone}
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom stats marquee -->
    <div class="border-t border-primary-foreground/10">
      <div class="mx-auto w-full max-w-6xl px-6 py-8 md:px-12 lg:px-20">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          <div class="group">
            <div class="text-3xl font-serif text-primary-foreground md:text-4xl">{site.yearsExperience}+</div>
            <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Years Experience</div>
          </div>
          <div class="group">
            <div class="text-3xl font-serif text-primary-foreground md:text-4xl">Local</div>
            <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">{site.location.county}</div>
          </div>
          <div class="group">
            <div class="text-3xl font-serif text-primary-foreground md:text-4xl">Free</div>
            <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Consultation</div>
          </div>
          <div class="group">
            <div class="text-3xl font-serif text-primary-foreground md:text-4xl">24/7</div>
            <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Emergency Line</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
