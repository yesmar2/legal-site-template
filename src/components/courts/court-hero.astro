---
interface Props {
  courtName: string;
  description: string;
}

const { courtName, description } = Astro.props as Props;
---
<section class="relative isolate overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 py-20 md:py-28">
  <div
    aria-hidden="true"
    class="absolute -top-40 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/25 via-indigo-500/15 to-transparent blur-3xl"
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px]"
  />

  <div class="relative mx-auto max-w-6xl px-6">
    <nav class="mb-5 flex items-center gap-2 text-sm text-slate-400">
      <a href="/" class="transition-colors hover:text-white">Home</a>
      <span>/</span>
      <a href="/courts" class="transition-colors hover:text-white">Courts</a>
      <span>/</span>
      <span class="text-slate-300">{courtName}</span>
    </nav>

    <h1 class="max-w-3xl text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl">
      {courtName}
    </h1>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-400 md:text-lg">
      {description}
    </p>
  </div>
</section>

