---
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import { site } from '../../config/site';

interface Props {
  courtName: string;
}

const { courtName } = Astro.props as Props;
---
<section class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6 text-center">
    <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
      Facing Charges at {courtName}?
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-slate-300">
      Our attorneys regularly appear at {courtName} and understand the local 
      procedures. Contact us for a {site.consultationText.toLowerCase()} about your case.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-slate-900 shadow-sm transition-colors hover:bg-slate-100"
      >
        <Calendar class="h-5 w-5" />
        {site.consultationText}
      </a>
      <a
        href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
        class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-transparent px-6 py-3 text-base font-semibold text-white hover:bg-white/10"
      >
        <Phone class="h-5 w-5" />
        {site.phone}
      </a>
    </div>
  </div>
</section>

