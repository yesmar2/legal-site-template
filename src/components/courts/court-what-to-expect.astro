---
interface ExpectationItem {
  text: string;
}

interface Props {
  beforeAppearance: ExpectationItem[];
  duringAppearance: ExpectationItem[];
}

const { beforeAppearance, duringAppearance } = Astro.props as Props;
---
<section class="py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
      What to Expect at Court
    </h2>
    <div class="mt-10 grid gap-10 md:grid-cols-2 md:gap-8">
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-foreground">Before Your Appearance</h3>
        <ul class="space-y-3 text-muted-foreground">
          {beforeAppearance.map((item, index) => (
            <li class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-medium text-primary">
                {index + 1}
              </span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-foreground">During Your Appearance</h3>
        <ul class="space-y-3 text-muted-foreground">
          {duringAppearance.map((item, index) => (
            <li class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-medium text-primary">
                {index + 1}
              </span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

