---
interface CaseType {
  icon: any;
  title: string;
  description: string;
}

interface Props {
  courtName: string;
  caseTypes: CaseType[];
}

const { courtName, caseTypes } = Astro.props as Props;
---
<section class="bg-muted py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
      Types of Cases Handled
    </h2>
    <p class="mt-3 max-w-2xl text-muted-foreground">
      {courtName} handles a variety of criminal, traffic, and civil matters.
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {caseTypes.map((caseType) => (
        <article class="rounded-2xl border border-border bg-card p-5 shadow-sm">
          <div class="flex items-start gap-4 pb-2">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
              <caseType.icon class="h-5 w-5 text-primary" />
            </div>
            <div>
              <h3 class="text-base font-semibold text-foreground">
                {caseType.title}
              </h3>
            </div>
          </div>
          <p class="pl-[3.5rem] text-sm text-muted-foreground">
            {caseType.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

