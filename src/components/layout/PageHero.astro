---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'section'> {
  title: string;
  badge?: string;
}

const { title, badge, class: className, ...rest } = Astro.props;
---

<section
  class:list={[
    'relative overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 py-20 md:py-28',
    className,
  ]}
  {...rest}
>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_30%,rgba(59,130,246,0.08),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_70%,rgba(59,130,246,0.05),transparent_50%)]"></div>
  <div aria-hidden="true" class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px]"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    {badge && (
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-800/50 px-4 py-1.5 text-sm text-slate-300">
        <slot name="badgeIcon" />
        {badge}
      </div>
    )}

    <h1 class="max-w-3xl text-balance text-4xl font-bold tracking-tight text-white md:text-5xl">
      {title}
    </h1>

    <div class="mt-4 max-w-2xl text-base leading-relaxed text-slate-300 md:text-lg">
      <slot />
    </div>
  </div>
</section>
