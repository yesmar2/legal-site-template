---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'section'> {
  title: string;
  badge?: string;
}

const { title, badge, class: className, ...rest } = Astro.props;
---

<section
  class:list={[
    'relative isolate overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 py-20 md:py-28',
    className,
  ]}
  {...rest}
>
  <div aria-hidden="true" class="absolute -top-40 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/30 via-indigo-500/20 to-transparent blur-3xl" />
  <div aria-hidden="true" class="absolute -bottom-20 right-0 -z-10 h-[350px] w-[350px] rounded-full bg-gradient-to-tl from-blue-600/20 via-cyan-500/10 to-transparent blur-3xl" />
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:72px_72px]" />

  <div class="relative mx-auto max-w-6xl px-6 text-center">
    {badge && (
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-800/50 px-4 py-1.5 text-sm text-slate-300">
        <slot name="badgeIcon" />
        {badge}
      </div>
    )}

    <h1 class="text-balance text-4xl font-bold tracking-tight text-white md:text-5xl">
      {title}
    </h1>

    <div class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-slate-300 md:text-lg">
      <slot />
    </div>
  </div>
</section>
