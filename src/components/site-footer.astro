---
import MapPin from '@lucide/astro/icons/map-pin';
import Phone from '@lucide/astro/icons/phone';
import Mail from '@lucide/astro/icons/mail';
import Clock from '@lucide/astro/icons/clock';
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';
import { site } from '../config/site';
import { practiceAreas } from '../data/practiceAreas';

const year = new Date().getFullYear();
---
<footer class="bg-foreground text-primary-foreground">
  <!-- Main footer content -->
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-12 md:py-24 lg:px-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-12 lg:gap-8">
      <!-- Firm info -->
      <div class="lg:col-span-4">
        <a href="/" class="font-serif text-2xl text-primary-foreground">
          {site.firmName}
        </a>
        <p class="mt-6 text-sm leading-relaxed text-primary-foreground/60">
          Providing over {site.yearsExperience} years of experienced legal representation to individuals and families 
          throughout {site.location.county}.
        </p>
      </div>

      <!-- Practice Areas -->
      <div class="lg:col-span-3">
        <h3 class="text-sm font-medium uppercase tracking-wider text-primary-foreground/40">Practice Areas</h3>
        <ul class="mt-6 space-y-3">
          {practiceAreas.map((area) => (
            <li>
              <a href={area.href} class="group inline-flex items-center gap-1 text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground">
                {area.name}
                <ArrowUpRight class="h-3 w-3 opacity-0 transition-opacity group-hover:opacity-100" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="lg:col-span-2">
        <h3 class="text-sm font-medium uppercase tracking-wider text-primary-foreground/40">Quick Links</h3>
        <ul class="mt-6 space-y-3">
          <li>
            <a href="/about" class="text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground">
              About Us
            </a>
          </li>
          <li>
            <a href="/guides" class="text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground">
              Guides
            </a>
          </li>
          <li>
            <a href="/courts" class="text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground">
              Local Courts
            </a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-primary-foreground/70 transition-colors hover:text-primary-foreground">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="lg:col-span-3">
        <h3 class="text-sm font-medium uppercase tracking-wider text-primary-foreground/40">Contact</h3>
        <ul class="mt-6 space-y-4">
          <li class="flex items-start gap-3 text-sm text-primary-foreground/70">
            <MapPin class="mt-0.5 h-4 w-4 shrink-0 text-primary-foreground/40" />
            <span>{site.address.street}, Suite 200<br />{site.address.city}, {site.address.state} {site.address.zip}</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-primary-foreground/70">
            <Phone class="h-4 w-4 shrink-0 text-primary-foreground/40" />
            <span>{site.phone}</span>
          </li>
          <li class="flex items-center gap-3 text-sm text-primary-foreground/70">
            <Mail class="h-4 w-4 shrink-0 text-primary-foreground/40" />
            <span>{site.email}</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-primary-foreground/70">
            <Clock class="mt-0.5 h-4 w-4 shrink-0 text-primary-foreground/40" />
            <span>
              Mon - Fri: 9AM - 5PM
              {site.isTwentyFourSeven && <><br />24/7 Emergency Line</>}
            </span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-primary-foreground/10">
    <div class="mx-auto max-w-6xl px-6 py-6 md:px-12 lg:px-20">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
        <p class="text-xs text-primary-foreground/40">
          {year} {site.firmName}. All rights reserved.
        </p>
        <p class="max-w-xl text-xs leading-relaxed text-primary-foreground/40">
          <strong class="text-primary-foreground/50">Legal Disclaimer:</strong> The information on this website is for general informational purposes only. 
          Nothing on this site should be taken as legal advice for any individual case or situation. 
          This information is not intended to create an attorney-client relationship.
        </p>
      </div>
    </div>
  </div>
</footer>
