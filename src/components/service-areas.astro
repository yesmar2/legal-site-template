---
import MapPin from '@lucide/astro/icons/map-pin';
import { site } from '../config/site';
import { practiceAreas } from '../data/practiceAreas';
import { courts } from '../data/courts';

const practiceAreaNames = practiceAreas.map((area) => area.name).join(', ');
const courtNames = courts.slice(0, 3).map((c) => c.name);
const courtsList =
  courtNames.length === 1
    ? courtNames[0]
    : courtNames.length === 2
      ? `${courtNames[0]} and ${courtNames[1]}`
      : `${courtNames.slice(0, -1).join(', ')}, and ${courtNames[courtNames.length - 1]}`;
---
<section class="border-y border-border bg-muted/30 py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
        Serving {site.location.city} &amp; {site.location.county}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-muted-foreground">
        We represent clients throughout {site.location.county} in {practiceAreaNames.toLowerCase()} matters.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      {site.serviceAreas.map((city) => (
        <div class="flex items-center gap-2 rounded-full border border-border bg-background px-5 py-2.5 text-sm font-medium text-foreground shadow-sm transition-colors hover:border-primary/50 hover:bg-primary/5">
          <MapPin class="h-4 w-4 text-primary" />
          {city}
        </div>
      ))}
    </div>
  </div>
</section>

