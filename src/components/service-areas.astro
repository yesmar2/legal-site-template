---
import MapPin from '@lucide/astro/icons/map-pin';
import { site } from '../config/site';
import { practiceAreas } from '../data/practiceAreas';
import { courts } from '../data/courts';

const practiceAreaNames = practiceAreas.map((area) => area.name).join(', ');
const courtNames = courts.slice(0, 3).map((c) => c.name);
const courtsList =
  courtNames.length === 1
    ? courtNames[0]
    : courtNames.length === 2
      ? `${courtNames[0]} and ${courtNames[1]}`
      : `${courtNames.slice(0, -1).join(', ')}, and ${courtNames[courtNames.length - 1]}`;
---
<section class="border-y border-border bg-background py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary">Service Areas</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Serving {site.location.city} & {site.location.county}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        We represent clients throughout {site.location.county} in {practiceAreaNames.toLowerCase()} matters.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {site.serviceAreas.map((city) => (
        <div class="group flex items-center gap-2 rounded-full border border-border bg-card px-5 py-2.5 text-sm font-medium text-foreground shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
          <MapPin class="h-4 w-4 text-primary" />
          {city}
        </div>
      ))}
    </div>
    
    <p class="mx-auto mt-10 max-w-2xl text-center text-base leading-relaxed text-muted-foreground">
      Our attorneys regularly represent clients in courts throughout {site.location.city} and {site.location.county}, including {courtsList}.
    </p>
  </div>
</section>
