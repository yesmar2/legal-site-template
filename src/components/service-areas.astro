---
import { site } from '../config/site';
import { practiceAreas } from '../data/practiceAreas';

const practiceAreaNames = practiceAreas.map((area) => area.name).join(', ');
---
<section class="border-y border-border bg-background py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-xl">
        <span class="text-sm uppercase tracking-widest text-muted-foreground">Service Areas</span>
        <h2 class="mt-4 font-serif text-4xl text-foreground md:text-5xl">
          Serving {site.location.city} & {site.location.county}
        </h2>
        <p class="mt-4 text-muted-foreground">
          We represent clients throughout {site.location.county} in {practiceAreaNames.toLowerCase()} matters.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        {site.serviceAreas.map((city) => (
          <span class="inline-flex border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-muted">
            {city}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
