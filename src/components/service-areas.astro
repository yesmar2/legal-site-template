---
import MapPin from '@lucide/astro/icons/map-pin';
import { site } from '../config/site';
import { practiceAreas } from '../data/practiceAreas';

const practiceAreaNames = practiceAreas.map((area) => area.name).join(', ');
---
<section class="border-y border-border bg-background py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary">Service Areas</p>
      <h2 class="text-pretty text-2xl font-bold tracking-tight text-foreground md:text-3xl lg:text-4xl">
        Serving {site.location.city} & {site.location.county}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        We represent clients throughout {site.location.county} in {practiceAreaNames.toLowerCase()} matters.
      </p>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-3 md:gap-4">
      {site.serviceAreas.map((city) => (
        <div class="flex items-center gap-2 rounded-full border border-border bg-card px-5 py-2.5 text-sm font-medium text-foreground shadow-sm transition-all hover:border-primary/30 hover:bg-primary/5 hover:shadow-md">
          <MapPin class="h-4 w-4 text-primary" />
          {city}
        </div>
      ))}
    </div>
  </div>
</section>
