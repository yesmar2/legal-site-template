---
import Scale from '@lucide/astro/icons/scale';
import Phone from '@lucide/astro/icons/phone';
import { site } from '../config/site';
---
<header class="sticky top-0 z-50 border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary">
        <Scale class="h-5 w-5 text-primary-foreground" />
      </div>
      <div>
        <span class="font-bold text-foreground">{site.firmName}</span>
        <span class="hidden text-xs text-muted-foreground sm:block">{site.location.county}</span>
      </div>
    </a>

    <!-- Simple navigation (desktop) -->
    <div class="hidden items-center gap-6 lg:flex">
      <a href="/#practice-areas" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
        Practice Areas
      </a>
      <a href="/guides" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
        Guides
      </a>
      <a href="/courts/jamestown-city-court" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
        Local Courts
      </a>
    </div>

    <!-- Phone number and CTA -->
    <div class="hidden items-center gap-4 md:flex">
      <a 
        href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`} 
        class="flex items-center gap-2 text-base font-semibold text-foreground transition-colors hover:text-primary"
      >
        <Phone class="h-5 w-5 text-primary" />
        {site.phone}
      </a>
      <a
        href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
        class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
      >
        {site.consultationText}
      </a>
    </div>
  </nav>

  <!-- Simple mobile bar (no JS) -->
  <div class="border-t bg-background px-6 py-3 text-sm md:hidden">
    <div class="flex flex-col gap-2">
      <a 
        href="tel:+17165551234" 
        class="flex items-center justify-center gap-2 rounded-md border border-input bg-background px-4 py-2 text-base font-semibold text-foreground transition-colors hover:bg-muted"
      >
        Call {site.phone}
      </a>
      <div class="flex items-center justify-center gap-3 text-xs text-muted-foreground">
        <a href="/#practice-areas" class="hover:text-foreground">Practice Areas</a>
        <span class="h-1 w-1 rounded-full bg-muted-foreground/40"></span>
        <a href="/courts/jamestown-city-court" class="hover:text-foreground">Courts</a>
        <span class="h-1 w-1 rounded-full bg-muted-foreground/40"></span>
        <a href="/guides" class="hover:text-foreground">Guides</a>
      </div>
    </div>
  </div>
</header>

