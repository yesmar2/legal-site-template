---
import Star from '@lucide/astro/icons/star';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';
import { testimonials } from '../data/testimonials';
---
<section class="bg-background py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
    <!-- Section header -->
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="text-sm uppercase tracking-widest text-muted-foreground">Testimonials</span>
        <h2 class="mt-2 font-serif text-4xl text-foreground md:text-5xl lg:text-6xl">
          What Our Clients Say
        </h2>
      </div>
      <p class="max-w-md text-muted-foreground">
        Real results for real people. Read what our clients have to say about their experience.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <article class="group relative flex flex-col border border-border bg-card p-8 transition-all hover:border-foreground/20">
          <!-- Star rating -->
          <div class="mb-6 flex gap-1">
            {[...Array(5)].map(() => (
              <Star class="h-4 w-4 fill-foreground text-foreground" />
            ))}
          </div>
          
          <!-- Quote -->
          <p class="flex-1 text-base leading-relaxed text-foreground">
            "{t.quote.replace('{{firmName}}', site.firmName)}"
          </p>
          
          <!-- Author -->
          <div class="mt-8 flex items-center justify-between border-t border-border pt-6">
            <div>
              <p class="font-medium text-foreground">{t.name}</p>
              <p class="text-sm text-muted-foreground">{t.role}</p>
            </div>
            <a
              href={t.url}
              target="_blank"
              rel="noreferrer"
              class="flex items-center gap-1 text-xs font-medium uppercase tracking-wider text-muted-foreground transition-colors hover:text-foreground"
            >
              Google
              <ArrowRight class="h-3 w-3" />
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
