---
import Star from '@lucide/astro/icons/star';
import Quote from '@lucide/astro/icons/quote';
import { site } from '../config/site';
import { testimonials } from '../data/testimonials';
---
<section class="bg-background py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary">Testimonials</p>
      <h2 class="text-pretty text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
        What Our Clients Say
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
        Hear from our satisfied clients about their experience working with us.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {testimonials.map((t) => (
        <article class="relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card p-8 shadow-sm transition-all hover:border-primary/30 hover:shadow-md">
          <!-- Large quote mark -->
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
            <span class="text-2xl font-bold text-primary">"</span>
          </div>
          
          <!-- Star rating -->
          <div class="mb-4 flex gap-0.5">
            <Star class="h-5 w-5 fill-primary text-primary" />
            <Star class="h-5 w-5 fill-primary text-primary" />
            <Star class="h-5 w-5 fill-primary text-primary" />
            <Star class="h-5 w-5 fill-primary text-primary" />
            <Star class="h-5 w-5 fill-primary text-primary" />
          </div>
          
          <p class="flex-1 text-base leading-relaxed text-muted-foreground">
            "{t.quote.replace('{{firmName}}', site.firmName)}"
          </p>
          
          <div class="mt-6 flex items-center justify-between border-t border-border pt-6">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10">
                <span class="text-sm font-bold text-primary">{t.name.charAt(0)}</span>
              </div>
              <div>
                <p class="font-semibold text-foreground">{t.name}</p>
                <p class="text-xs text-muted-foreground">{t.role}</p>
              </div>
            </div>
            <a
              href={t.url}
              target="_blank"
              rel="noreferrer"
              class="text-xs font-semibold uppercase tracking-wide text-primary transition-colors hover:text-primary/80"
            >
              Google
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
