---
import Star from '@lucide/astro/icons/star';
import { site } from '../config/site';
import { testimonials } from '../data/testimonials';
---
<section class="bg-muted/30 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary">Testimonials</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl lg:text-5xl">
        What Our Clients Say
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        Real results for real people. Read what our clients have to say about their experience working with us.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {testimonials.map((t, index) => (
        <article class="group relative flex h-full flex-col rounded-2xl border border-border bg-card p-8 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg">
          <!-- Large quote mark -->
          <div class="mb-4 text-5xl font-serif leading-none text-primary/20">"</div>
          
          <!-- Star rating -->
          <div class="mb-4 flex gap-0.5">
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
          </div>
          
          <p class="flex-1 text-base leading-relaxed text-muted-foreground">
            "{t.quote.replace('{{firmName}}', site.firmName)}"
          </p>
          
          <div class="mt-6 flex items-center gap-4 border-t border-border pt-6">
            <!-- Avatar placeholder -->
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary">
              {t.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div class="flex-1">
              <p class="font-semibold text-foreground">{t.name}</p>
              <p class="text-sm text-muted-foreground">{t.role}</p>
            </div>
            <a
              href={t.url}
              target="_blank"
              rel="noreferrer"
              class="text-xs font-medium text-primary transition-colors duration-200 hover:text-primary/80 hover:underline"
            >
              Review on Google
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
