---
import Star from '@lucide/astro/icons/star';
import Quote from '@lucide/astro/icons/quote';
import { site } from '../config/site';
import { testimonials } from '../data/testimonials';
---
<section class="bg-muted py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        What Our Clients Say
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
        Real results for real people. Read what our clients have to say about their experience working with us.
      </p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {testimonials.map((t) => (
        <article class="relative flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card p-8 shadow-sm">
          <Quote class="absolute -top-4 right-4 h-16 w-16 text-primary/10" />
          <div class="mb-4 flex gap-0.5">
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
            <Star class="h-4 w-4 fill-primary text-primary" />
          </div>
          <p class="relative z-10 leading-relaxed text-muted-foreground">
            "{t.quote.replace('{{firmName}}', site.firmName)}"
          </p>
          <div class="mt-6 flex items-center justify-between border-t pt-4 text-sm">
            <div>
              <p class="font-semibold text-foreground">{t.name}</p>
              <p class="text-xs text-muted-foreground">{t.role}</p>
            </div>
            <a
              href={t.url}
              target="_blank"
              rel="noreferrer"
              class="text-xs font-medium uppercase tracking-wide text-primary hover:underline"
            >
              Review on Google
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

