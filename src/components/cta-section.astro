---
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import { site } from '../config/site';
---
<section class="bg-gradient-to-br from-primary via-accent to-primary py-20 md:py-24">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-primary-foreground md:text-4xl">
      Ready to Discuss Your Case?
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-primary-foreground/80 md:text-lg">
      Don't face legal challenges alone. Contact us today for a free, confidential 
      consultation to discuss your situation and learn about your options.
    </p>

    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a 
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-full bg-primary-foreground px-6 py-3 text-base font-semibold text-primary shadow-sm transition-colors hover:bg-white"
      >
        <Calendar class="h-5 w-5" />
        Schedule {site.consultationText}
      </a>
      <a 
        href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
        class="inline-flex items-center justify-center gap-2 rounded-full border border-primary-foreground/30 bg-transparent px-6 py-3 text-base font-semibold text-primary-foreground hover:bg-primary-foreground/10 hover:text-primary-foreground"
      >
        <Phone class="h-5 w-5" />
        {site.phone}
      </a>
    </div>

    <p class="mt-8 text-sm text-primary-foreground/70">
      {site.isTwentyFourSeven && site.hasEveningAndWeekendAppointments && 'Available 24/7 for emergencies. Evening and weekend appointments available.'}
      {site.isTwentyFourSeven && !site.hasEveningAndWeekendAppointments && 'Available 24/7 for emergencies.'}
      {!site.isTwentyFourSeven && site.hasEveningAndWeekendAppointments && 'Evening and weekend appointments available.'}
    </p>
  </div>
</section>

