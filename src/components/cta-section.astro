---
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import Scale from '@lucide/astro/icons/scale';
import { site } from '../config/site';
---
<section class="bg-foreground py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-pretty text-3xl font-bold tracking-tight text-background md:text-4xl lg:text-5xl">
        Ready to Discuss Your Case?
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-background/70">
        Don't face legal challenges alone. Contact {site.firmName} today for a free, confidential 
        consultation to discuss your situation and learn about your legal options.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a 
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-8 py-4 text-base font-semibold text-primary-foreground shadow-lg shadow-primary/30 transition-all hover:bg-primary/90 hover:shadow-xl"
        >
          <Calendar class="h-5 w-5" />
          Schedule Your Free Consultation
        </a>
        <a 
          href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-background/20 bg-transparent px-8 py-4 text-base font-semibold text-background transition-all hover:bg-background/10"
        >
          <Phone class="h-5 w-5" />
          {site.phone}
        </a>
      </div>

      <p class="mt-8 text-sm text-background/60">
        {site.isTwentyFourSeven && site.hasEveningAndWeekendAppointments && 'Available 24/7. Evening and weekend appointments available.'}
        {site.isTwentyFourSeven && !site.hasEveningAndWeekendAppointments && 'Available 24/7 for emergencies.'}
        {!site.isTwentyFourSeven && site.hasEveningAndWeekendAppointments && 'Evening and weekend appointments available.'}
      </p>

      <!-- Trust badge -->
      <div class="mt-12 inline-flex items-center gap-3 rounded-full border border-background/10 bg-background/5 px-6 py-3">
        <Scale class="h-5 w-5 text-primary" />
        <span class="text-sm text-background/80">Trusted by clients across {site.location.county}</span>
      </div>
    </div>
  </div>
</section>
