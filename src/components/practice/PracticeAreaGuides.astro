---
import { guides } from '@/src/content/guides';
import GuideCard from '@/src/components/GuideCard.astro';
import CardGrid from '@/src/components/layout/CardGrid.astro';
import { site } from '@/src/config/site';

interface Practice {
  slug: string;
  name: string;
}

const { practice } = Astro.props as { practice: Practice };

const relatedGuides = guides.filter((guide) => guide.practiceArea === practice.slug);
---

{relatedGuides.length > 0 && (
  <section class="bg-background py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
        Related Legal Guides for {practice.name}
      </h2>
      <p class="mt-3 max-w-2xl text-muted-foreground">
        Learn more about {practice.name.toLowerCase()} matters and how cases are handled in {site.location.city} and throughout {site.location.county}.
      </p>

      <CardGrid class="mt-8">
        {relatedGuides.map((guide) => (
          <GuideCard guide={guide} />
        ))}
      </CardGrid>
    </div>
  </section>
)}

