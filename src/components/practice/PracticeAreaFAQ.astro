---
import { site } from '../../config/site';

interface FAQItem {
  question: string;
  answer: string;
}

interface Practice {
  slug: string;
  name: string;
  faqs?: FAQItem[];
}

const { practice } = Astro.props as { practice: Practice };

const faqs: FAQItem[] = Array.isArray(practice.faqs) ? practice.faqs : [];
---
{faqs.length > 0 && (
  <section class="bg-background py-20 md:py-28">
    <div class="mx-auto max-w-3xl px-6">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          Frequently Asked Questions
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">
          Get answers to common questions about {practice.name.toLowerCase()} in {site.location.city} and
          {` ${site.location.county}`}. For specific advice about your case, contact us for a {site.consultationText.toLowerCase()}.
        </p>
      </div>

      <div class="mt-12 space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-border bg-card px-4 py-3">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-base font-medium text-foreground">
              <span>{faq.question}</span>
              <span class="shrink-0 text-lg transition-transform group-open:rotate-90">›</span>
            </summary>
            <div class="mt-2 border-t border-border pt-3 text-sm leading-relaxed text-muted-foreground">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

