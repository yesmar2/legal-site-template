---
import Building2 from '@lucide/astro/icons/building-2';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { courts } from '@/src/content/courts';
import CourtCard from '@/src/components/CourtCard.astro';

const { practiceArea } = Astro.props;

const relatedCourts = Array.isArray(practiceArea.courts)
  ? courts.filter((court) => practiceArea.courts.includes(court.slug))
  : [];
---

{relatedCourts.length > 0 && (
  <section class="bg-muted py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
          Courts Where We Handle {practiceArea.name} Cases
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Our attorneys regularly represent clients in {practiceArea.name.toLowerCase()} cases in several courts
          throughout Chautauqua County.
        </p>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {relatedCourts.map((court) => (
          <CourtCard court={court} variant="summary" />
        ))}
      </div>
    </div>
  </section>
)}

