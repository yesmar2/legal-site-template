---
import { site } from '../../config/site';
import type { PracticeArea } from '@/src/types/practice';

const { practice } = Astro.props as { practice: PracticeArea };

const rawParagraphs =
  practice.introParagraphs && practice.introParagraphs.length > 0
    ? practice.introParagraphs
    : [practice.heroDescription ?? practice.description ?? ''];

const paragraphs = rawParagraphs.map((p) =>
  p.replace(/\{\{firmName\}\}/g, site.firmName)
);
---

<section class="bg-background py-20 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
      {practice.name} Representation in {site.location.city}
    </h2>

    <div class="mt-6 space-y-5 text-base leading-relaxed text-muted-foreground md:text-lg">
      {paragraphs.map((p) => (
        <p>{p}</p>
      ))}
    </div>
  </div>
</section>
