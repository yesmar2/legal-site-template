---
import Scale from '@lucide/astro/icons/scale';
import Building2 from '@lucide/astro/icons/building-2';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Phone from '@lucide/astro/icons/phone';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import { site } from '@/src/config/site';
import { practiceAreas } from '../data/practiceAreas';
import { courts } from '../data/courts';
import { caseTypes } from '@/src/data/caseTypes';
import PracticeAreaCard from '@/src/components/PracticeAreaCard.astro';
import CardGrid from '@/src/components/layout/CardGrid.astro';

const pageTitle = `${site.firmName} Practice Areas`;
const pageDescription = `${site.firmName} represents clients throughout ${site.location.county} in criminal defense, personal injury, family law, real estate law, and other legal matters.`;
const formatCaseTypeLabel = (title: string) =>
  title
    .replace('DUI / DWI Defense', 'DUI Defense')
    .replace('Slip & Fall', 'Slip and Fall')
    .replace('Assault Charges', 'Assault Defense')
    .replace('Landlord–Tenant Matters', 'Landlord Tenant Issues');
const featuredCourtSlugs = [
  'jamestown-city-court',
  'chautauqua-county-court',
  'dunkirk-city-court',
  'ellicott-town-court'
] as const;
const featuredCourts = featuredCourtSlugs
  .map((slug) => courts.find((court) => court.slug === slug))
  .filter((court): court is (typeof courts)[number] => Boolean(court));
const jamestownCourt = featuredCourts.find((court) => court?.slug === 'jamestown-city-court');
const countyCourt = featuredCourts.find((court) => court?.slug === 'chautauqua-county-court');
const phoneHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <!-- Hero with subtle gradient background -->
      <section class="relative overflow-hidden bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900 py-20 md:py-28">
        <!-- Subtle pattern overlay -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(59,130,246,0.08),transparent_50%)]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(59,130,246,0.05),transparent_50%)]"></div>
        
        <div class="relative mx-auto max-w-4xl px-6 text-center">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-800/50 px-4 py-1.5 text-sm text-slate-300">
            <Scale class="h-4 w-4 text-blue-400" />
            Legal Services in {site.location.county}
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-white md:text-5xl">
            Practice Areas
          </h1>
          <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-300 md:text-lg">
            {site.firmName} provides legal representation throughout {site.location.city} and {site.location.county}, {site.location.state} in several practice areas including criminal defense, personal injury, family law, and real estate law. Our attorneys regularly represent clients in local courts such as{' '}
            {jamestownCourt && (
              <a href={jamestownCourt.href} class="font-medium text-blue-400 hover:text-blue-300 hover:underline">
                {jamestownCourt.name}
              </a>
            )}
            {' '}and{' '}
            {countyCourt && (
              <a href={countyCourt.href} class="font-medium text-blue-400 hover:text-blue-300 hover:underline">
                {countyCourt.name}
              </a>
            )}
            , representing clients in a wide range of legal matters.
          </p>
        </div>
      </section>

      <!-- Practice Area Cards with warm accent borders -->
      <section class="bg-background py-20 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
          <CardGrid gapClass="gap-6">
            {practiceAreas.map((area) => {
              return <PracticeAreaCard practiceArea={area} variant="list" />;
            })}
          </CardGrid>
        </div>
      </section>

      <!-- Courts Section with subtle slate background -->
      <section class="border-y border-slate-200 bg-slate-50 py-20 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mx-auto max-w-3xl text-center">
            <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-slate-200/80 px-3 py-1 text-xs font-medium uppercase tracking-wider text-slate-600">
              <Building2 class="h-3.5 w-3.5" />
              Local Courts
            </div>
            <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
              Courts We Regularly Appear In
            </h2>
            <p class="mt-4 text-base leading-relaxed text-muted-foreground md:text-lg">
              Our attorneys regularly represent clients in several courts throughout {site.location.county}.
            </p>
          </div>

          <div class="mt-10 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
            {featuredCourts.map((court) => (
              <a href={court.href} class="group block">
                <div class="h-full rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/50 hover:shadow-lg">
                  <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-slate-100">
                    <Building2 class="h-5 w-5 text-slate-600" />
                  </div>
                  <h3 class="flex items-center gap-2 text-base font-semibold text-foreground">
                    {court.name}
                    <ArrowRight class="h-4 w-4 text-primary opacity-0 transition-all group-hover:translate-x-1 group-hover:opacity-100" />
                  </h3>
                  <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary">
                    View Court Page
                    <ArrowRight class="h-3.5 w-3.5" />
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section with gradient -->
      <section class="relative overflow-hidden bg-gradient-to-br from-primary via-accent to-primary py-20 md:py-24">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.1),transparent_50%)]"></div>
        <div class="relative mx-auto max-w-4xl px-6 text-center">
          <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
            Need Help With a Legal Matter?
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/80 md:text-lg">
            Speak with an attorney today about your case.
            Free consultations are available for many legal matters.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-white/90">
            <span class="flex items-center gap-1.5"><span class="text-white">&#10003;</span> Free Consultation</span>
            <span class="flex items-center gap-1.5"><span class="text-white">&#10003;</span> Local Attorneys</span>
            <span class="flex items-center gap-1.5"><span class="text-white">&#10003;</span> Serving {site.location.city} &amp; {site.location.county}</span>
          </div>
          <a
            href={phoneHref}
            class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-primary shadow-lg transition-all hover:bg-white/90 hover:shadow-xl"
          >
            <Phone class="h-5 w-5" />
            Call Now For a Free Consultation
          </a>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
