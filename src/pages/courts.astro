---
import Building2 from '@lucide/astro/icons/building-2';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Calendar from '@lucide/astro/icons/calendar';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import { site } from '@/src/config/site';
import { courts } from '../content/courts';

const pageTitle = `Courts We Serve | ${site.firmName}`;
const pageDescription = `Learn about the courts throughout ${site.location.county} where ${site.firmName} regularly represents clients.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <!-- Hero -->
      <section class="relative min-h-[50vh] overflow-hidden bg-foreground">
        <div class="absolute inset-0">
          <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center opacity-30" />
          <div class="absolute inset-0 bg-foreground/70" />
        </div>

        <div class="relative z-10 flex min-h-[50vh] flex-col justify-center px-6 py-24 md:px-12 lg:px-20">
          <div class="mx-auto w-full max-w-6xl">
            <span class="text-sm uppercase tracking-widest text-primary-foreground/50">Local Courts</span>
            <h1 class="mt-4 max-w-4xl font-serif text-4xl text-primary-foreground sm:text-5xl md:text-6xl lg:text-7xl">
              Courts We Serve
            </h1>
            <p class="mt-6 max-w-xl text-lg text-primary-foreground/70 md:text-xl">
              {site.copy.localCourtsLead.replace('{{county}}', site.location.county)}
            </p>
          </div>
        </div>
      </section>

      <!-- Courts grid -->
      <section class="bg-background py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {courts.map((court) => (
              <a href={`/courts/${court.slug}`} class="group">
                <article class="flex h-full flex-col border border-border bg-card p-8 transition-all duration-300 hover:border-foreground/20">
                  <div class="mb-6 flex h-12 w-12 items-center justify-center border border-border bg-muted">
                    <Building2 class="h-5 w-5 text-foreground" />
                  </div>
                  <h2 class="font-serif text-xl text-foreground md:text-2xl">{court.name}</h2>
                  {('location' in court) && (court as any).location?.city && (
                    <p class="mt-1 text-sm text-muted-foreground">
                      {(court as any).location.city}
                    </p>
                  )}
                  <p class="mt-4 flex-1 text-base leading-relaxed text-muted-foreground line-clamp-3">
                    {court.cardDescription || court.description}
                  </p>
                  <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-foreground">
                    View Court Details
                    <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
                  </span>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Info section -->
      <section class="bg-muted py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">
            <div>
              <span class="text-sm uppercase tracking-widest text-muted-foreground">Why It Matters</span>
              <h2 class="mt-4 font-serif text-4xl text-foreground md:text-5xl">
                Local Court Experience Matters
              </h2>
            </div>
            <div class="flex flex-col justify-end">
              <p class="text-lg leading-relaxed text-muted-foreground">
                Every court has its own procedures, prosecutors, and judges. Our firm represents clients in courts throughout {site.location.county} and understands how cases move through the local court system.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="bg-foreground py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="flex flex-col gap-12 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-2xl">
              <span class="text-sm uppercase tracking-widest text-primary-foreground/50">Get Started</span>
              <h2 class="mt-4 font-serif text-4xl text-primary-foreground md:text-5xl lg:text-6xl">
                Facing a Case in One of These Courts?
              </h2>
              <p class="mt-6 text-lg text-primary-foreground/70">
                Contact our office today to discuss your situation with an attorney.
              </p>
            </div>

            <a
              href="/contact"
              class="group inline-flex items-center justify-center gap-3 bg-primary-foreground px-8 py-4 text-sm font-medium text-foreground transition-all hover:bg-primary-foreground/90"
            >
              <Calendar class="h-4 w-4" />
              Schedule {site.consultationText}
              <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </a>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
