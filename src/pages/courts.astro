---
import Building2 from '@lucide/astro/icons/building-2';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import PageHero from '@/src/components/layout/PageHero.astro';
import PageCTA from '@/src/components/layout/PageCTA.astro';
import { site } from '@/src/config/site';
import { courts } from '../data/courts';
import CourtCard from '@/src/components/CourtCard.astro';
import CardGrid from '@/src/components/layout/CardGrid.astro';

const pageTitle = `Courts We Serve | ${site.firmName}`;
const pageDescription = `Learn about the courts throughout ${site.location.county} where ${site.firmName} regularly represents clients.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <PageHero title="Courts We Serve" badge={`${site.location.county} Courts`}>
        <Building2 slot="badgeIcon" class="h-4 w-4 text-blue-400" />
        <p>
          {site.copy.localCourtsLead.replace('{{county}}', site.location.county)} including{' '}
          <a href="/courts/jamestown-city-court" class="font-medium text-blue-400 hover:text-blue-300 hover:underline">Jamestown City Court</a>
          {' '}and{' '}
          <a href="/courts/chautauqua-county-court" class="font-medium text-blue-400 hover:text-blue-300 hover:underline">Chautauqua County Court</a>.
        </p>
      </PageHero>

      <section class="bg-background py-20 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
          <CardGrid gapClass="gap-6">
            {courts.map((court) => (
              <CourtCard court={court} variant="full" />
            ))}
          </CardGrid>
        </div>
      </section>

      <!-- Experience Section -->
      <section class="border-y border-slate-200 bg-slate-50 py-20 md:py-24">
        <div class="mx-auto max-w-3xl px-6 text-center">
          <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-slate-200/80 px-3 py-1 text-xs font-medium uppercase tracking-wider text-slate-600">
            Why It Matters
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
            Local Court Experience Matters
          </h2>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground md:text-lg">
            Every court has its own procedures, prosecutors, and judges. Our firm represents clients in courts throughout {site.location.county} and understands how cases move through the local court system.
          </p>
        </div>
      </section>

      <PageCTA
        title="Facing a Case in One of These Courts?"
        description="Contact our office today to discuss your situation with an attorney."
        buttonText={`Schedule ${site.consultationText}`}
        buttonHref="/contact"
      />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
