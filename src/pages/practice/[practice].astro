---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import PracticeHero from '@/src/components/practice-hero.astro';
import { practiceAreas } from '../../data/practiceAreas';

export async function getStaticPaths() {
  return practiceAreas.map((practice) => ({
    params: { practice: practice.slug },
    props: practice
  }));
}

const practice = Astro.props;
---

<BaseLayout title={practice.title} description={practice.description}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <PracticeHero practice={practice} />

      {practice.sections?.map((section) => {
        const Section = section;
        return <Section practice={practice} />;
      })}
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

