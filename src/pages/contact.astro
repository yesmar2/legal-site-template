---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import Phone from '@lucide/astro/icons/phone';
import MapPin from '@lucide/astro/icons/map-pin';
import Mail from '@lucide/astro/icons/mail';
import Clock from '@lucide/astro/icons/clock';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { site } from '../config/site';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
---

<BaseLayout
  title={`Contact ${site.firmName}`}
  description={`Contact ${site.firmName} in ${site.location.city}, ${site.location.state} to discuss your case and schedule a ${site.consultationText.toLowerCase()}.`}
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main class="flex-1">
      <!-- Hero -->
      <section class="relative min-h-[50vh] overflow-hidden bg-foreground">
        <div class="absolute inset-0">
          <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop')] bg-cover bg-center opacity-30" />
          <div class="absolute inset-0 bg-foreground/70" />
        </div>

        <div class="relative z-10 flex min-h-[50vh] flex-col justify-center px-6 py-24 md:px-12 lg:px-20">
          <div class="mx-auto w-full max-w-6xl">
            <span class="text-sm uppercase tracking-widest text-primary-foreground/50">Contact</span>
            <h1 class="mt-4 max-w-3xl font-serif text-4xl text-primary-foreground sm:text-5xl md:text-6xl">
              Get in Touch
            </h1>
            <p class="mt-6 max-w-xl text-lg text-primary-foreground/70 md:text-xl">
              Speak with a local attorney about your case. Call today for a {site.consultationText.toLowerCase()}.
            </p>
          </div>
        </div>
      </section>

      <!-- Contact content -->
      <section class="bg-background py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">
            <!-- Left column - Call to action -->
            <div>
              <span class="text-sm uppercase tracking-widest text-muted-foreground">Call Us</span>
              <h2 class="mt-4 font-serif text-4xl text-foreground md:text-5xl">
                Call to Discuss Your Case
              </h2>
              <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
                The quickest way to reach us is by phone. If we are in court when you call, leave a message and we will return your call as soon as possible.
              </p>

              <a
                href={telHref}
                class="group mt-8 inline-flex items-center justify-center gap-3 bg-foreground px-8 py-4 text-sm font-medium text-primary-foreground transition-all hover:bg-foreground/90"
              >
                <Phone class="h-4 w-4" />
                Call {site.phone}
                <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </a>

              <p class="mt-4 text-sm text-muted-foreground">
                Free consultations available. If this is an emergency, call now.
              </p>
            </div>

            <!-- Right column - Contact info -->
            <div class="border-l border-border pl-16">
              <span class="text-sm uppercase tracking-widest text-muted-foreground">Office</span>
              <h3 class="mt-4 font-serif text-2xl text-foreground">
                Office Information
              </h3>

              <div class="mt-8 space-y-6">
                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-muted">
                    <MapPin class="h-4 w-4 text-foreground" />
                  </div>
                  <div>
                    <p class="text-sm font-medium uppercase tracking-wider text-muted-foreground">Address</p>
                    <p class="mt-1 text-foreground">
                      {site.address.street}<br />
                      {site.address.city}, {site.address.state} {site.address.zip}
                    </p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-muted">
                    <Phone class="h-4 w-4 text-foreground" />
                  </div>
                  <div>
                    <p class="text-sm font-medium uppercase tracking-wider text-muted-foreground">Phone</p>
                    <p class="mt-1 text-foreground">{site.phone}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-muted">
                    <Mail class="h-4 w-4 text-foreground" />
                  </div>
                  <div>
                    <p class="text-sm font-medium uppercase tracking-wider text-muted-foreground">Email</p>
                    <p class="mt-1 text-foreground">{site.email}</p>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center border border-border bg-muted">
                    <Clock class="h-4 w-4 text-foreground" />
                  </div>
                  <div>
                    <p class="text-sm font-medium uppercase tracking-wider text-muted-foreground">Hours</p>
                    <p class="mt-1 text-foreground">
                      Mon - Fri: 9AM - 5PM
                      {site.isTwentyFourSeven && <><br />24/7 Emergency Line</>}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Form placeholder -->
      <section class="bg-muted py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="mx-auto max-w-2xl border border-border bg-card p-12 text-center">
            <span class="text-sm uppercase tracking-widest text-muted-foreground">Coming Soon</span>
            <h2 class="mt-4 font-serif text-3xl text-foreground">
              Send Us a Message
            </h2>
            <p class="mt-4 text-muted-foreground">
              Online consultation requests will be available soon. For now, please call our office directly to speak with an attorney about your situation.
            </p>
          </div>
        </div>
      </section>

      <!-- Service area -->
      <section class="bg-background py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 text-center md:px-12 lg:px-20">
          <span class="text-sm uppercase tracking-widest text-muted-foreground">Service Area</span>
          <h2 class="mt-4 font-serif text-3xl text-foreground md:text-4xl">
            Serving {site.location.city} & {site.location.county}
          </h2>
          <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
            Serving clients throughout {site.location.county}, including {site.location.city} and the surrounding communities.
          </p>
        </div>
      </section>

      <!-- Disclaimer -->
      <section class="border-t border-border bg-muted py-12">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <p class="text-center text-xs text-muted-foreground">
            Contacting our firm does not create an attorney-client relationship. Please do not send confidential information until an attorney-client relationship has been established.
          </p>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
