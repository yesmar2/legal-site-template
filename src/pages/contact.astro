---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import Phone from '@lucide/astro/icons/phone';
import { site } from '../config/site';

const telHref = `tel:${site.phone.replace(/[^0-9+]/g, '')}`;
const mapQuery = encodeURIComponent(
  `${site.address.street}, ${site.address.city}, ${site.address.state} ${site.address.zip}`
);
---

<BaseLayout
  title={`Contact ${site.firmName}`}
  description={`Contact ${site.firmName} in ${site.location.city}, ${site.location.state} to discuss your case and schedule a ${site.consultationText.toLowerCase()}.`}
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main class="flex-1">
      <!-- ContactHero -->
      <section class="relative isolate overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 py-20 md:py-28">
        <div aria-hidden="true" class="absolute -top-40 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/30 via-indigo-500/20 to-transparent blur-3xl" />
        <div aria-hidden="true" class="absolute -bottom-20 right-0 -z-10 h-[350px] w-[350px] rounded-full bg-gradient-to-tl from-blue-600/20 via-cyan-500/10 to-transparent blur-3xl" />
        <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:72px_72px]" />
        <div class="relative mx-auto max-w-6xl px-6 text-center">
          <h1 class="mx-auto max-w-3xl text-balance text-4xl font-bold tracking-tight text-white md:text-5xl">
            Contact {site.firmName}
          </h1>
          <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-slate-300 md:text-lg">
            Speak with a local attorney about your case. Call today for a {site.consultationText.toLowerCase()}.
          </p>
        </div>
      </section>

      <!-- CallSection -->
      <section class="bg-background py-20 md:py-24">
        <div class="mx-auto max-w-6xl px-6 text-center">
          <h2 class="text-2xl font-semibold tracking-tight text-foreground md:text-3xl">
            Call to Discuss Your Case
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">
            The quickest way to reach us is by phone. If we are in court when you call, leave a message and we will return your call as soon as possible.
          </p>
          <a
            href={telHref}
            class="mt-8 inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
          >
            <Phone class="h-5 w-5" />
            Call {site.phone}
          </a>
          <p class="mt-4 text-sm text-muted-foreground">
            Free consultations available. If this is an emergency, call now.
          </p>
        </div>
      </section>

      <!-- Contact form -->
      <section class="bg-muted py-20 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mx-auto max-w-2xl rounded-2xl border border-border bg-card p-8 shadow-sm">
            <h2 class="text-center text-2xl font-semibold tracking-tight text-foreground md:text-3xl">
              Send Us a Message
            </h2>
            <form
              action="https://formspree.io/f/REPLACE_WITH_FORM_ID"
              method="POST"
              class="mx-auto mt-6 space-y-4 max-w-xl"
            >
              <div>
                <label for="name" class="block text-sm font-medium text-foreground">Name</label>
                <input
                  type="text"
                  name="name"
                  id="name"
                  required
                  class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-base text-foreground"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-foreground">Email</label>
                <input
                  type="email"
                  name="email"
                  id="email"
                  required
                  class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-base text-foreground"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-foreground">Phone</label>
                <input
                  type="tel"
                  name="phone"
                  id="phone"
                  class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-base text-foreground"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-foreground">How can we help?</label>
                <textarea
                  name="message"
                  id="message"
                  rows="4"
                  required
                  class="mt-1 w-full rounded-md border border-input bg-background px-3 py-2 text-base text-foreground"
                />
              </div>
              <button
                type="submit"
                class="w-full rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground hover:bg-primary/90 sm:w-auto"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </section>

      <!-- Map -->
      <section class="bg-muted py-12 md:py-16">
        <div class="mx-auto max-w-6xl px-6">
          <h2 class="text-center text-2xl font-semibold tracking-tight text-foreground md:text-3xl">
            Our Office Location
          </h2>
          <div class="mt-8 w-full overflow-hidden rounded-xl">
            <iframe
              src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
              width="100%"
              height="450"
              style="border: 0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
              title="Office location map"
            />
          </div>
        </div>
      </section>

      <!-- ContactDisclaimer -->
      <section class="bg-muted py-12 md:py-16">
        <div class="mx-auto max-w-6xl px-6">
          <p class="mx-auto max-w-2xl text-center text-xs leading-relaxed text-muted-foreground">
            Contacting our firm does not create an attorney-client relationship. Please do not send confidential information until an attorney-client relationship has been established.
          </p>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

