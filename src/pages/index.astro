---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import HeroSection from '@/src/components/hero-section.astro';
import FirmIntro from '@/src/components/firm-intro.astro';
import PracticeAreas from '@/src/components/practice-areas.astro';
import WhyChooseUs from '@/src/components/why-choose-us.astro';
import AttorneySection from '@/src/components/attorney-section.astro';
import ServiceAreas from '@/src/components/service-areas.astro';
import LocalCourtsHome from '@/src/components/local-courts-home.astro';
import Testimonials from '@/src/components/testimonials.astro';
import CTASection from '@/src/components/cta-section.astro';
import SiteFooter from '@/src/components/site-footer.astro';
---
<BaseLayout
  title="Anderson Law Firm | Criminal Defense & Personal Injury Attorneys"
  description="Experienced criminal defense and personal injury attorneys serving Chautauqua County. Free consultations available. Call today for dedicated legal representation."
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <HeroSection />
      <FirmIntro />
      <section id="practice-areas">
        <PracticeAreas />
      </section>
      <WhyChooseUs />
      <section id="attorney">
        <AttorneySection />
      </section>
      <ServiceAreas />
      <LocalCourtsHome />
      <Testimonials />
      <CTASection />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
