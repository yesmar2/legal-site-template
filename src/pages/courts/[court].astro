---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import CourtHero from '@/src/components/courts/court-hero.astro';
import CourtAbout from '@/src/components/courts/court-about.astro';
import CourtCaseTypes from '@/src/components/courts/court-case-types.astro';
import CourtWhatToExpect from '@/src/components/courts/court-what-to-expect.astro';
import CourtRelatedAreas from '@/src/components/courts/court-related-areas.astro';
import CourtCTA from '@/src/components/courts/court-cta.astro';
import { courts } from '../../data/courts';
import { guides } from '../../data/guides';

export async function getStaticPaths() {
  return courts.map((court) => ({
    params: { court: court.slug },
    props: { slug: court.slug }
  }));
}

const { slug } = Astro.props as { slug: string };
const courtData = courts.find((court) => court.slug === slug);

if (!courtData) {
  throw new Error(`Court not found for slug: ${slug}`);
}

const relatedGuides = guides.filter((guide) =>
  guide.courts?.includes(slug)
);
---

<BaseLayout title={courtData.page.title} description={courtData.page.description}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <CourtHero courtName={courtData.name} description={courtData.page.description} />
      <CourtAbout
        courtName={courtData.name}
        paragraphs={courtData.aboutParagraphs}
        location={courtData.location}
      />
      <CourtCaseTypes courtName={courtData.name} caseTypes={courtData.caseTypes} />
      <CourtWhatToExpect
        beforeAppearance={courtData.beforeAppearance}
        duringAppearance={courtData.duringAppearance}
      />
      <CourtRelatedAreas areas={courtData.relatedAreas} />
      {Array.isArray(courtData.sources) && courtData.sources.length > 0 && (
        <section class="border-t border-border bg-background py-10">
          <div class="mx-auto max-w-6xl px-6">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">
              Official Sources
            </h3>
            <ul class="mt-3 space-y-1 text-sm text-muted-foreground">
              {courtData.sources.map((source) => (
                <li>
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:underline"
                  >
                    {source.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}
      {relatedGuides.length > 0 && (
        <section class="border-t border-border bg-background py-16 md:py-20">
          <div class="mx-auto max-w-6xl px-6">
            <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
              Legal Guides Related to This Court
            </h2>
            <p class="mt-3 max-w-2xl text-muted-foreground">
              Learn more about legal processes that take place in this court.
            </p>
            <ul class="mt-6 list-disc space-y-2 pl-6">
              {relatedGuides.map((guide) => (
                <li>
                  <a
                    href={`/guides/${guide.slug}`}
                    class="text-primary hover:underline"
                  >
                    {guide.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}
      <CourtCTA courtName={courtData.name} />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

