---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import CriminalDefenseHero from '@/src/components/criminal-defense/hero.astro';
import CriminalDefenseOverview from '@/src/components/criminal-defense/overview.astro';
import CriminalCaseTypes from '@/src/components/criminal-defense/case-types.astro';
import CriminalDefensePenalties from '@/src/components/criminal-defense/penalties.astro';
import CriminalDefenseFAQ from '@/src/components/criminal-defense/faq.astro';
import CriminalDefenseResources from '@/src/components/criminal-defense/resources.astro';
import CriminalDefenseAttorney from '@/src/components/criminal-defense/attorney.astro';
import CriminalDefenseCTA from '@/src/components/criminal-defense/cta.astro';
---
<BaseLayout
  title="Jamestown Criminal Defense Lawyer | DUI, Drug Charges & Assault Defense"
  description="Experienced criminal defense attorneys in Jamestown, NY. We defend clients facing DUI, drug charges, assault, domestic violence, and theft crimes in Chautauqua County."
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <CriminalDefenseHero />
      <CriminalDefenseOverview />
      <CriminalCaseTypes />
      <CriminalDefensePenalties />
      <CriminalDefenseFAQ />
      <CriminalDefenseResources />
      <CriminalDefenseAttorney />
      <CriminalDefenseCTA />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
