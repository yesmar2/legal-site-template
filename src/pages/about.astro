---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import User from '@lucide/astro/icons/user';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Phone from '@lucide/astro/icons/phone';
import { site } from '../config/site';
import { attorneys } from '../content/attorneys';
import { courts } from '../content/courts';

const pageTitle = `About ${site.firmName}`;
const pageDescription = `${site.firmName} is a law firm based in ${site.location.city}, ${site.location.state}, representing clients throughout ${site.location.county}.`;

const yearsExp = site.yearsExperience ?? 20;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <!-- Hero section -->
      <section class="relative min-h-[70vh] overflow-hidden bg-foreground">
        <div class="absolute inset-0">
          <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center opacity-30" />
          <div class="absolute inset-0 bg-foreground/70" />
        </div>

        <div class="relative z-10 flex min-h-[70vh] flex-col justify-center px-6 py-24 md:px-12 lg:px-20">
          <div class="mx-auto w-full max-w-6xl">
            <span class="text-sm uppercase tracking-widest text-primary-foreground/50">About</span>
            <h1 class="mt-4 max-w-4xl font-serif text-4xl text-primary-foreground sm:text-5xl md:text-6xl lg:text-7xl">
              {site.firmName}
            </h1>
            <p class="mt-6 max-w-xl text-lg text-primary-foreground/70 md:text-xl">
              A law firm based in {site.location.city}, {site.location.state}, representing clients throughout {site.location.county}.
            </p>
          </div>
        </div>

        <!-- Stats bar -->
        <div class="relative z-10 border-t border-primary-foreground/10">
          <div class="mx-auto w-full max-w-6xl px-6 py-8 md:px-12 lg:px-20">
            <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
              <div>
                <div class="font-serif text-3xl text-primary-foreground md:text-4xl">{yearsExp}+</div>
                <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Years Experience</div>
              </div>
              <div>
                <div class="font-serif text-3xl text-primary-foreground md:text-4xl">Local</div>
                <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Court Knowledge</div>
              </div>
              <div>
                <div class="font-serif text-3xl text-primary-foreground md:text-4xl">Free</div>
                <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Consultations</div>
              </div>
              <div>
                <div class="font-serif text-3xl text-primary-foreground md:text-4xl">24/7</div>
                <div class="mt-1 text-sm text-primary-foreground/50 uppercase tracking-wider">Emergency Line</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Firm overview -->
      <section class="bg-background py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">
            <div>
              <span class="text-sm uppercase tracking-widest text-muted-foreground">Our Practice</span>
              <h2 class="mt-4 font-serif text-4xl text-foreground md:text-5xl">
                {site.tagline}
              </h2>
            </div>
            <div class="flex flex-col justify-end">
              <p class="text-lg leading-relaxed text-muted-foreground">
                {site.firmName} represents individuals and families in criminal defense, personal injury, family law, and related matters. Our attorneys focus on protecting clients' rights and achieving the best possible outcomes in {site.location.city} and across {site.location.county}.
              </p>
              <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
                The firm regularly represents clients in local courts throughout {site.location.county}, {site.location.state}. We understand local procedures and work to provide responsive, effective representation close to home.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Attorneys -->
      <section class="bg-muted py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <span class="text-sm uppercase tracking-widest text-muted-foreground">Our Team</span>
              <h2 class="mt-2 font-serif text-4xl text-foreground md:text-5xl">
                Meet Our Attorneys
              </h2>
            </div>
            <p class="max-w-md text-muted-foreground">
              Experienced attorneys representing clients throughout {site.location.city} and {site.location.county}.
            </p>
          </div>

          <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {attorneys.map((attorney) => {
              const att = attorney as typeof attorney & { experience?: string; focusList?: string[] };
              return (
                <a href={attorney.href} class="group">
                  <article class="flex h-full flex-col border border-border bg-card p-8 transition-all duration-300 hover:border-foreground/20">
                    <div class="mb-6 flex h-20 w-20 items-center justify-center border border-border bg-muted">
                      <User class="h-8 w-8 text-muted-foreground" />
                    </div>
                    <h3 class="font-serif text-2xl text-foreground">{attorney.name}</h3>
                    {att.experience && (
                      <p class="mt-1 text-sm text-muted-foreground">{att.experience}</p>
                    )}
                    <p class="mt-2 text-sm font-medium uppercase tracking-wider text-muted-foreground">
                      {attorney.title}
                    </p>
                    <p class="mt-4 flex-1 text-base leading-relaxed text-muted-foreground">
                      {attorney.focus}
                    </p>
                    <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-foreground">
                      View Profile
                      <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
                    </span>
                  </article>
                </a>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Courts section -->
      <section class="bg-background py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <span class="text-sm uppercase tracking-widest text-muted-foreground">Local Courts</span>
              <h2 class="mt-2 font-serif text-4xl text-foreground md:text-5xl">
                Courts & Community
              </h2>
            </div>
            <a 
              href="/courts" 
              class="group inline-flex items-center gap-2 text-sm font-medium text-foreground"
            >
              View All Courts
              <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </a>
          </div>

          <p class="mt-6 max-w-2xl text-muted-foreground">
            {site.firmName} regularly appears in local courts throughout {site.location.county}.
          </p>

          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {courts.map((court) => (
              <a href={`/courts/${court.slug}`} class="group">
                <article class="flex h-full flex-col border border-border bg-card p-8 transition-all duration-300 hover:border-foreground/20">
                  <h3 class="font-serif text-xl text-foreground">{court.name}</h3>
                  {('location' in court) && (court as any).location?.city && (
                    <p class="mt-1 text-sm text-muted-foreground">
                      {(court as any).location.city}
                    </p>
                  )}
                  <p class="mt-4 flex-1 text-base leading-relaxed text-muted-foreground line-clamp-3">
                    {court.cardDescription}
                  </p>
                  <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-foreground">
                    View Court
                    <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
                  </span>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA section -->
      <section class="bg-foreground py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-12 lg:px-20">
          <div class="flex flex-col gap-12 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-2xl">
              <span class="text-sm uppercase tracking-widest text-primary-foreground/50">Get Started</span>
              <h2 class="mt-4 font-serif text-4xl text-primary-foreground md:text-5xl lg:text-6xl">
                Speak With a Local Attorney
              </h2>
              <p class="mt-6 text-lg text-primary-foreground/70">
                If you need legal representation in {site.location.city} or throughout {site.location.county}, contact {site.firmName} to schedule a consultation.
              </p>
            </div>

            <div class="flex flex-col gap-4 sm:flex-row">
              <a 
                href="/contact"
                class="group inline-flex items-center justify-center gap-3 bg-primary-foreground px-8 py-4 text-sm font-medium text-foreground transition-all hover:bg-primary-foreground/90"
              >
                Contact Us
                <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </a>
              {site.phone && (
                <a 
                  href={`tel:${site.phone.replace(/[^0-9+]/g, '')}`}
                  class="inline-flex items-center justify-center gap-3 border border-primary-foreground/30 px-8 py-4 text-sm font-medium text-primary-foreground transition-all hover:border-primary-foreground/60"
                >
                  <Phone class="h-4 w-4" />
                  {site.phone}
                </a>
              )}
            </div>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
