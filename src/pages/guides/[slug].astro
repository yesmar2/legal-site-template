---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import { guides } from '@/src/data/guides';
import { courts } from '@/src/data/courts';
import { site } from '@/src/config/site';
import { practiceLabels, courtLabels } from '@/src/config/labels';
import Building2 from '@lucide/astro/icons/building-2';
import Check from '@lucide/astro/icons/check';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import GuideCard from '@/src/components/GuideCard.astro';
import type { Guide } from '@/src/types/content';

export async function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props as { guide: Guide };

const relatedGuides = guides.filter(
  (g) => g.practiceArea === guide.practiceArea && g.slug !== guide.slug
);

const relevantCourts = Array.isArray(guide.courts)
  ? guide.courts
      .map((slug) => courts.find((court) => court.slug === slug))
      .filter((court): court is (typeof courts)[number] => Boolean(court))
  : [];

const processSteps = Array.isArray(guide.processSteps) ? guide.processSteps : [];
const faqs = Array.isArray(guide.faqs) ? guide.faqs : [];
const localResources = Array.isArray(guide.localResources) ? guide.localResources : [];
const lawyerHelp = guide.lawyerHelp;
const hasCustomLawyerHelp =
  Boolean(lawyerHelp && Array.isArray(lawyerHelp.bullets) && lawyerHelp.bullets.length > 0);
const defaultLawyerHelpIntro =
  'A criminal defense lawyer can guide you through each stage of the case and work to protect your rights and future.';
const defaultLawyerHelpBullets = [
  'Review the legality of the traffic stop, arrest, and any searches.',
  'Challenge chemical test results and other key pieces of evidence.',
  'Negotiate with prosecutors for reduced charges or alternative sentencing.',
  'Represent you in court hearings, pre-trial motions, and trial if necessary.',
];
const lawyerHelpHeading = lawyerHelp?.heading ?? 'How a Lawyer Can Help';
/** Custom guides: omit paragraph when `intro` is unset. Default guides: criminal-defense intro. */
const lawyerHelpIntro = hasCustomLawyerHelp ? lawyerHelp!.intro : defaultLawyerHelpIntro;
const lawyerHelpBullets = hasCustomLawyerHelp ? lawyerHelp!.bullets : defaultLawyerHelpBullets;
---

<BaseLayout
  title={`${guide.title} | ${site.firmName}`}
  description={guide.description}
>
  <div class="flex min-h-screen flex-col bg-background">
    <SiteHeader />
    <main>
      <!-- Hero - Dark with legal themed background -->
      <section class="relative isolate overflow-hidden bg-slate-950 pb-16 pt-8 md:pb-24 md:pt-12">
        <!-- Grid pattern overlay -->
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
        
        <!-- Gradient accents -->
        <div aria-hidden="true" class="pointer-events-none absolute -left-40 top-0 h-[500px] w-[500px] rounded-full bg-primary/10 blur-3xl"></div>
        <div aria-hidden="true" class="pointer-events-none absolute -right-40 bottom-0 h-[400px] w-[400px] rounded-full bg-primary/5 blur-3xl"></div>
        
        <!-- Legal scale icon - decorative -->
        <div aria-hidden="true" class="pointer-events-none absolute right-8 top-1/2 hidden -translate-y-1/2 opacity-[0.04] lg:block xl:right-16">
          <svg class="h-[400px] w-[400px] text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5">
            <path d="M12 3v18M3 6l9-3 9 3M3 6v2c0 1.5 2 3 5 3s5-1.5 5-3V6M16 6v2c0 1.5 2 3 5 3s5-1.5 5-3V6" />
            <circle cx="7" cy="8" r="3" />
            <circle cx="17" cy="8" r="3" />
            <path d="M4 9l3 8h0a3 3 0 0 0 6 0h0l3-8M14 9l3 8h0a3 3 0 0 0 6 0h0l3-8" />
          </svg>
        </div>
        
        <div class="relative mx-auto max-w-6xl px-6">
          <!-- Breadcrumb -->
          <nav class="mb-8 flex items-center gap-1.5 text-sm text-slate-400">
            <a href="/" class="transition-colors hover:text-white">Home</a>
            <ChevronRight class="h-3.5 w-3.5" />
            <a href="/guides" class="transition-colors hover:text-white">Guides</a>
            <ChevronRight class="h-3.5 w-3.5" />
            <span class="text-slate-300">{guide.title}</span>
          </nav>

          <!-- Practice area badge -->
          <a 
            href={`/practice/${guide.practiceArea}`}
            class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary transition-colors hover:bg-primary/20"
          >
            {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea}
            <ArrowRight class="h-3 w-3" />
          </a>

          <h1 class="max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl">
            {guide.title}
          </h1>
          
          <p class="mt-6 max-w-2xl text-pretty text-base leading-relaxed text-slate-300 md:text-lg">
            {guide.description}
          </p>

          <!-- Meta info row -->
          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-400">
            {guide.court && (
              <a
                href={`/courts/${guide.court}`}
                class="flex items-center gap-1.5 transition-colors hover:text-primary"
              >
                <Building2 class="h-4 w-4" />
                {courtLabels[guide.court] ?? guide.court}
              </a>
            )}
            {guide.city && guide.county && (
              <span class="flex items-center gap-1.5">
                <span class="h-1 w-1 rounded-full bg-slate-600"></span>
                {guide.city}, {guide.county}
              </span>
            )}
            <span class="flex items-center gap-1.5">
              <span class="h-1 w-1 rounded-full bg-slate-600"></span>
              Updated {guide.lastReviewed ?? 'March 2026'}
            </span>
          </div>
        </div>
      </section>

      <!-- Guide content - Modern editorial layout -->
      <section class="py-16 md:py-20">
        <div class="mx-auto max-w-6xl px-6">
          <div class="grid gap-16 lg:grid-cols-12 lg:gap-12">
            <!-- Main content -->
            <article class="guide-article lg:col-span-8">
              
              <!-- Quick Answer - Cleaner presentation -->
              {guide.quickAnswer && (
                <div class="relative overflow-hidden rounded-xl bg-secondary/50 p-6 md:p-8">
                  <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-primary/5"></div>
                  <p class="relative text-sm leading-relaxed text-muted-foreground md:text-base">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-wider text-primary">Quick Answer</span>
                    {guide.quickAnswer}
                  </p>
                </div>
              )}

              <!-- Overview section -->
              <section id="overview" class="guide-section scroll-mt-24">
                <h2>Overview</h2>
                <p class="mt-4 text-muted-foreground">
                  This guide explains the legal process related to this situation in {guide.city ?? site.location.city} and {guide.county ?? site.location.county} courts.
                </p>

                {Array.isArray(guide.takeaways) && guide.takeaways.length > 0 && (
                  <div class="mt-8">
                    <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
                      Key Takeaways
                    </h3>
                    <ul class="space-y-3">
                      {guide.takeaways.map((point) => (
                        <li class="flex items-start gap-3 text-sm leading-relaxed text-muted-foreground">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span>
                          <span>{point}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </section>
              
              <!-- Process Steps - Timeline style -->
              {processSteps.length > 0 && (
                <section id="legal-process" class="guide-section scroll-mt-24">
                  <h2>Step-by-Step Legal Process</h2>
                  <div class="relative mt-8">
                    <!-- Timeline line -->
                    <div class="absolute bottom-0 left-5 top-0 w-px bg-border md:left-6"></div>
                    
                    <div class="space-y-8">
                      {processSteps.map((step, index) => (
                        <div class="relative flex gap-4 md:gap-6">
                          <!-- Step number -->
                          <div class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-background text-sm font-semibold text-primary ring-4 ring-background md:h-12 md:w-12">
                            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 md:h-10 md:w-10">
                              {String(index + 1).padStart(2, '0')}
                            </span>
                          </div>
                          
                          <!-- Step content -->
                          <div class="flex-1 pb-2 pt-1">
                            <h3 class="text-base font-semibold text-foreground md:text-lg">
                              {step.title}
                            </h3>
                            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                              {step.description}
                            </p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </section>
              )}

              <!-- Courts - Simplified cards -->
              {relevantCourts.length > 0 && (
                <section id="courts" class="guide-section scroll-mt-24">
                  <h2>Relevant Courts</h2>
                  <div class="mt-6 space-y-3">
                    {relevantCourts.map((court) => (
                      <a
                        href={court.href ?? `/courts/${court.slug}`}
                        class="group flex items-center justify-between rounded-lg border border-border bg-card p-4 transition-all hover:border-primary/30 hover:bg-secondary/50 md:p-5"
                      >
                        <div class="flex items-center gap-4">
                          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                            <Building2 class="h-5 w-5" />
                          </div>
                          <div>
                            <h3 class="font-medium text-foreground group-hover:text-primary">
                              {court.name}
                            </h3>
                            {court.cardDescription && (
                              <p class="mt-0.5 text-sm text-muted-foreground">
                                {court.cardDescription}
                              </p>
                            )}
                          </div>
                        </div>
                        <ArrowRight class="h-5 w-5 text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-primary" />
                      </a>
                    ))}
                  </div>
                </section>
              )}

              <!-- How a Lawyer Can Help -->
              <section id="lawyer-help" class="guide-section scroll-mt-24">
                <h2>{lawyerHelpHeading}</h2>
                {lawyerHelpIntro && (
                  <p class="mt-4 text-muted-foreground">
                    {lawyerHelpIntro}
                  </p>
                )}
                <ul class="mt-6 space-y-4">
                  {lawyerHelpBullets.map((bullet) => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed text-muted-foreground">
                      <span class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10">
                        <Check class="h-3 w-3 text-primary" />
                      </span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </section>

              <!-- FAQs - Accordion style -->
              {faqs.length > 0 && (
                <section id="faq" class="guide-section scroll-mt-24">
                  <h2>Frequently Asked Questions</h2>
                  <div class="mt-6 divide-y divide-border">
                    {faqs.map((faq) => (
                      <details class="group py-4 first:pt-0 last:pb-0">
                        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-medium text-foreground transition-colors hover:text-primary">
                          <span>{faq.question}</span>
                          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-muted-foreground transition-all group-open:rotate-45 group-open:bg-primary/10 group-open:text-primary">
                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path d="M12 5v14M5 12h14" />
                            </svg>
                          </span>
                        </summary>
                        <div class="mt-3 pr-12 text-sm leading-relaxed text-muted-foreground">
                          {faq.answer}
                        </div>
                      </details>
                    ))}
                  </div>
                </section>
              )}

              <!-- Why Choose Local -->
              <section class="guide-section" id="why-choose-local">
                <h2>Why Choose a Local {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea} Lawyer</h2>
                <div class="mt-6 grid gap-3 sm:grid-cols-2">
                  <div class="flex items-start gap-3 rounded-lg bg-secondary/50 p-4">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                      <Check class="h-3.5 w-3.5" />
                    </span>
                    <span class="text-sm text-muted-foreground">Experience in local courts</span>
                  </div>
                  <div class="flex items-start gap-3 rounded-lg bg-secondary/50 p-4">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                      <Check class="h-3.5 w-3.5" />
                    </span>
                    <span class="text-sm text-muted-foreground">Familiarity with local prosecutors</span>
                  </div>
                  <div class="flex items-start gap-3 rounded-lg bg-secondary/50 p-4">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                      <Check class="h-3.5 w-3.5" />
                    </span>
                    <span class="text-sm text-muted-foreground">Understanding of New York criminal procedure</span>
                  </div>
                  <div class="flex items-start gap-3 rounded-lg bg-secondary/50 p-4">
                    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                      <Check class="h-3.5 w-3.5" />
                    </span>
                    <span class="text-sm text-muted-foreground">Representation at every stage of the case</span>
                  </div>
                </div>
              </section>

              <!-- Sources -->
              {Array.isArray(guide.sources) && guide.sources.length > 0 && (
                <section class="guide-section">
                  <h2>Sources</h2>
                  <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
                    {guide.sources.map((source) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-muted-foreground"></span>
                        {source.url ? (
                          <a
                            href={source.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-primary underline-offset-2 hover:underline"
                          >
                            {source.title ?? source.url}
                          </a>
                        ) : (
                          <span>{source.title}</span>
                        )}
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              <!-- CTA - Clean and prominent -->
              <section class="guide-section">
                <div class="relative overflow-hidden rounded-xl bg-primary p-8 text-primary-foreground md:p-10">
                  <!-- Decorative elements -->
                  <div class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-primary-foreground/10"></div>
                  <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-primary-foreground/5"></div>
                  
                  <div class="relative">
                    <h2 class="text-xl font-semibold md:text-2xl">
                      {guide.cta?.headline ?? `Need legal guidance for this situation?`}
                    </h2>
                    <p class="mt-3 text-sm leading-relaxed text-primary-foreground/80 md:text-base">
                      {guide.cta?.body ??
                        `A lawyer can explain your options, appear with you in local courts, and work to protect your rights. Call ${site.phone} to speak with ${site.firmName}.`}
                    </p>
                    <a
                      href="/contact"
                      class="mt-6 inline-flex items-center gap-2 rounded-full bg-primary-foreground px-6 py-3 text-sm font-semibold text-primary transition-all hover:gap-3"
                    >
                      Schedule Consultation
                      <ArrowRight class="h-4 w-4" />
                    </a>
                  </div>
                </div>
              </section>

              <!-- Related Guides -->
              {relatedGuides.length > 0 && (
                <section class="guide-section">
                  <h2>Other Guides for {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea}</h2>
                  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
                    {relatedGuides.slice(0, 2).map((related) => (
                      <GuideCard guide={related} />
                    ))}
                  </div>
                </section>
              )}
            </article>

            <!-- Sidebar - Cleaner, less boxy -->
            <aside class="space-y-8 lg:sticky lg:top-24 lg:col-span-4 lg:self-start">
              
              <!-- Primary CTA Card -->
              <div class="rounded-xl bg-secondary/70 p-6">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                  Need Help?
                </h2>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  If you've been arrested for DUI or another criminal charge in {site.location.city} or anywhere in {site.location.county}, speaking with a local defense attorney early can help protect your record and driving privileges.
                </p>
                <a
                  href="/contact"
                  class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
                >
                  Schedule Consultation
                  <ArrowRight class="h-4 w-4" />
                </a>
              </div>

              <!-- Local Courts - Simplified list -->
              <div>
                <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                  Local Courts
                </h2>
                <div class="mt-4 space-y-2">
                  <a href="/courts/jamestown-city-court" class="flex items-center gap-3 rounded-lg p-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                    <Building2 class="h-4 w-4 text-primary" />
                    Jamestown City Court
                  </a>
                  <a href="/courts/dunkirk-city-court" class="flex items-center gap-3 rounded-lg p-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                    <Building2 class="h-4 w-4 text-primary" />
                    Dunkirk City Court
                  </a>
                  <a href="/courts/chautauqua-county-court" class="flex items-center gap-3 rounded-lg p-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                    <Building2 class="h-4 w-4 text-primary" />
                    Chautauqua County Court
                  </a>
                </div>
              </div>

              <!-- Local Resources -->
              {localResources.length > 0 && (
                <div>
                  <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                    Local Resources
                  </h2>
                  <div class="mt-4 space-y-4">
                    {localResources.map((resource) => (
                      <div class="text-sm">
                        <div class="flex items-start gap-2">
                          <Building2 class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
                          <div class="min-w-0">
                            {resource.href ? (
                              <a
                                href={resource.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="font-medium text-foreground hover:text-primary"
                              >
                                {resource.label}
                              </a>
                            ) : (
                              <p class="font-medium text-foreground">{resource.label}</p>
                            )}
                            {resource.description && (
                              <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
                                {resource.description}
                              </p>
                            )}
                            {Array.isArray(resource.details) && resource.details.length > 0 && (
                              <ul class="mt-2 space-y-1 text-xs leading-relaxed text-muted-foreground">
                                {resource.details.map((detail) => (
                                  <li>{detail}</li>
                                ))}
                              </ul>
                            )}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </aside>
          </div>
        </div>
      </section>

    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .guide-article {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .guide-section h2 {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  @media (min-width: 768px) {
    .guide-section h2 {
      font-size: 1.5rem;
    }
  }

  .guide-section p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted-foreground);
  }

  /* Smooth accordion animation */
  details[open] > summary ~ * {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Remove default marker */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
