---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import { guides } from '@/src/content/guides';
import { site } from '@/src/config/site';

export async function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;

const courtLabels: Record<string, string> = {
  "jamestown-city-court": "Jamestown City Court",
  "chautauqua-county-court": "Chautauqua County Court",
  "chautauqua-county-family-court": "Chautauqua County Family Court",
  "dunkirk-city-court": "Dunkirk City Court",
};
---

<BaseLayout
  title={`${guide.title} | ${site.firmName}`}
  description={guide.description}
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <!-- Hero -->
      <section class="relative isolate overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 pb-20 pt-28 md:pb-24 md:pt-36">
        <div aria-hidden="true" class="absolute -top-40 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/30 via-indigo-500/20 to-transparent blur-3xl" />
        <div aria-hidden="true" class="absolute -bottom-20 right-0 -z-10 h-[350px] w-[350px] rounded-full bg-gradient-to-tl from-blue-600/20 via-cyan-500/10 to-transparent blur-3xl" />
        <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px]" />

        <div class="relative mx-auto max-w-4xl px-6 lg:px-8">
          <h1 class="text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl md:text-6xl">
            {guide.title}
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-slate-400 md:text-xl">
            {guide.description}
          </p>
        </div>
      </section>

      <!-- Guide content -->
      <section class="bg-background py-16 md:py-24">
        <div class="mx-auto max-w-3xl px-6 lg:px-8">
          <article class="guide-article">
            {guide.courts && guide.courts.length > 0 && (
              <section class="guide-section">
                <h2>Relevant Courts</h2>
                <ul class="court-links">
                  {guide.courts.map((courtSlug) => (
                    <li>
                      <a href={`/courts/${courtSlug}`}>
                        {courtLabels[courtSlug] ?? courtSlug}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )}

            <section class="guide-section">
              <h2>Overview</h2>
              <p>
                This guide explains the legal process related to this situation in {site.location.city} and {site.location.county} courts.
              </p>
            </section>

            <section class="guide-section">
              <h2>Legal Process</h2>
              <p>
                Describe the step-by-step process someone typically goes through in this legal situation.
              </p>
            </section>

            <section class="guide-section">
              <h2>Local Court Information</h2>
              <p>
                Explain how this situation is handled in local courts such as {site.location.city} City Court or {site.location.county} Court.
              </p>
            </section>

            <section class="guide-section">
              <h2>How a Lawyer Can Help</h2>
              <p>
                Explain how legal representation helps during this process.
              </p>
            </section>

            <section class="guide-section">
              <h2>{site.consultationText}</h2>
              <p>
                If you are facing this legal situation, contact {site.firmName} to discuss your case. Call {site.phone} or reach out online to schedule a {site.consultationText.toLowerCase()}.
              </p>
              <a
                href="/contact"
                class="mt-4 inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
              >
                Contact {site.firmName}
              </a>
            </section>
          </article>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .guide-article {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .guide-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .guide-section p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted-foreground);
  }

  .court-links {
    margin: 0;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .court-links li {
    margin-bottom: 0.5rem;
  }

  .court-links a {
    font-size: 1rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .court-links a:hover {
    text-decoration: underline;
  }
</style>
