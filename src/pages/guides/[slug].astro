---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import { guides } from '@/src/data/guides';
import { courts } from '@/src/data/courts';
import { site } from '@/src/config/site';
import { practiceLabels, courtLabels } from '@/src/config/labels';
import Building2 from '@lucide/astro/icons/building-2';
import Check from '@lucide/astro/icons/check';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import MapPin from '@lucide/astro/icons/map-pin';
import Users from '@lucide/astro/icons/users';
import FileText from '@lucide/astro/icons/file-text';
import Shield from '@lucide/astro/icons/shield';
import BookOpen from '@lucide/astro/icons/book-open';
import GuideCard from '@/src/components/GuideCard.astro';
import type { Guide } from '@/src/types/content';

export async function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props as { guide: Guide };

const relatedGuides = guides.filter(
  (g) => g.practiceArea === guide.practiceArea && g.slug !== guide.slug
);

const relevantCourts = Array.isArray(guide.courts)
  ? guide.courts
      .map((slug) => courts.find((court) => court.slug === slug))
      .filter((court): court is (typeof courts)[number] => Boolean(court))
  : [];

const processSteps = Array.isArray(guide.processSteps) ? guide.processSteps : [];
const faqs = Array.isArray(guide.faqs) ? guide.faqs : [];
const localResources = Array.isArray(guide.localResources) ? guide.localResources : [];
const lawyerHelp = guide.lawyerHelp;
const hasCustomLawyerHelp =
  Boolean(lawyerHelp && Array.isArray(lawyerHelp.bullets) && lawyerHelp.bullets.length > 0);
const defaultLawyerHelpIntro =
  'A criminal defense lawyer can guide you through each stage of the case and work to protect your rights and future.';
const defaultLawyerHelpBullets = [
  'Review the legality of the traffic stop, arrest, and any searches.',
  'Challenge chemical test results and other key pieces of evidence.',
  'Negotiate with prosecutors for reduced charges or alternative sentencing.',
  'Represent you in court hearings, pre-trial motions, and trial if necessary.',
];
const lawyerHelpHeading = lawyerHelp?.heading ?? 'How a Lawyer Can Help';
/** Custom guides: omit paragraph when `intro` is unset. Default guides: criminal-defense intro. */
const lawyerHelpIntro = hasCustomLawyerHelp ? lawyerHelp!.intro : defaultLawyerHelpIntro;
const lawyerHelpBullets = hasCustomLawyerHelp ? lawyerHelp!.bullets : defaultLawyerHelpBullets;

// Calculate reading time (average 200 words per minute)
const wordCount = [
  guide.description,
  guide.quickAnswer,
  ...processSteps.map(s => s.title + ' ' + s.description),
  ...faqs.map(f => f.question + ' ' + f.answer),
  lawyerHelpIntro,
  ...lawyerHelpBullets,
].filter(Boolean).join(' ').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Build table of contents
const tocItems = [
  { id: 'overview', label: 'Overview' },
  ...(processSteps.length > 0 ? [{ id: 'legal-process', label: 'Legal Process' }] : []),
  ...(relevantCourts.length > 0 ? [{ id: 'courts', label: 'Courts' }] : []),
  { id: 'lawyer-help', label: 'How a Lawyer Can Help' },
  ...(faqs.length > 0 ? [{ id: 'faq', label: 'FAQs' }] : []),
  { id: 'why-choose-local', label: 'Why Choose Local' },
];
---

<BaseLayout
  title={`${guide.title} | ${site.firmName}`}
  description={guide.description}
>
  <div class="flex min-h-screen flex-col bg-background">
    <!-- Skip to main content link for keyboard users -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none">
      Skip to main content
    </a>
    
    <SiteHeader />
    <main id="main-content">
      <!-- Hero - Dark with legal themed CSS background -->
      <section class="relative isolate overflow-hidden bg-gradient-to-r from-slate-900 via-blue-950 to-blue-900 pb-16 pt-8 md:pb-24 md:pt-12">
        <!-- SVG decorative elements -->
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
          <!-- Abstract flowing curves -->
          <svg class="absolute inset-0 h-full w-full" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="curve-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="rgba(255,255,255,0.02)" />
                <stop offset="50%" stop-color="rgba(255,255,255,0.06)" />
                <stop offset="100%" stop-color="rgba(255,255,255,0.03)" />
              </linearGradient>
            </defs>
            <!-- Layered flowing curves -->
            <path d="M0,100 Q200,50 400,100 T800,100 T1200,100 T1600,100 T2000,100" fill="none" stroke="url(#curve-gradient)" stroke-width="1" />
            <path d="M0,140 Q200,90 400,140 T800,140 T1200,140 T1600,140 T2000,140" fill="none" stroke="url(#curve-gradient)" stroke-width="1" />
            <path d="M0,180 Q200,130 400,180 T800,180 T1200,180 T1600,180 T2000,180" fill="none" stroke="url(#curve-gradient)" stroke-width="1" />
            <path d="M0,220 Q200,170 400,220 T800,220 T1200,220 T1600,220 T2000,220" fill="none" stroke="url(#curve-gradient)" stroke-width="1" />
            <path d="M0,260 Q200,210 400,260 T800,260 T1200,260 T1600,260 T2000,260" fill="none" stroke="url(#curve-gradient)" stroke-width="1" />
            <path d="M0,300 Q200,250 400,300 T800,300 T1200,300 T1600,300 T2000,300" fill="none" stroke="url(#curve-gradient)" stroke-width="1" />
          </svg>
          
          <!-- Abstract circular accents on the right -->
          <div class="absolute -right-20 top-1/2 h-64 w-64 -translate-y-1/2 rounded-full border border-white/[0.05] md:-right-16 md:h-80 md:w-80 lg:-right-12 lg:h-96 lg:w-96"></div>
          <div class="absolute -right-8 top-1/2 h-48 w-48 -translate-y-1/2 rounded-full border border-white/[0.04] md:-right-4 md:h-60 md:w-60 lg:right-0 lg:h-72 lg:w-72"></div>
          <div class="absolute right-8 top-1/2 h-32 w-32 -translate-y-1/2 rounded-full border border-white/[0.03] md:right-12 md:h-40 md:w-40 lg:right-16 lg:h-48 lg:w-48"></div>
          
          <!-- Soft glow accents -->
          <div class="absolute -left-32 top-1/4 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl"></div>
          <div class="absolute -right-32 bottom-1/4 h-80 w-80 rounded-full bg-blue-400/10 blur-3xl"></div>
        </div>
        
        <div class="relative mx-auto max-w-6xl px-6">
          <!-- Breadcrumb -->
          <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-1.5 text-sm text-sky-100/80">
            <ol class="flex items-center gap-1.5">
              <li><a href="/" class="transition-colors hover:text-white">Home</a></li>
              <li aria-hidden="true"><ChevronRight class="h-3.5 w-3.5" /></li>
              <li><a href="/guides" class="transition-colors hover:text-white">Guides</a></li>
              <li aria-hidden="true"><ChevronRight class="h-3.5 w-3.5" /></li>
              <li aria-current="page" class="text-white">{guide.title}</li>
            </ol>
          </nav>

          <!-- Practice area badge -->
          <a 
            href={`/practice/${guide.practiceArea}`}
            class="mb-4 inline-flex items-center gap-2 rounded-full border border-sky-300/30 bg-sky-400/20 px-3 py-1 text-xs font-medium text-sky-100 backdrop-blur-sm transition-colors hover:bg-sky-400/30"
          >
            {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea}
            <ArrowRight class="h-3 w-3" />
          </a>

          <h1 class="max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl">
            {guide.title}
          </h1>
          
          <p class="mt-6 max-w-2xl text-pretty text-base leading-relaxed text-slate-300 md:text-lg">
            {guide.description}
          </p>

          <!-- Meta info row -->
          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-sky-100/80">
            {guide.court && (
              <a
                href={`/courts/${guide.court}`}
                class="flex items-center gap-1.5 text-sky-200 transition-colors hover:text-white"
              >
                <Building2 class="h-4 w-4" />
                {courtLabels[guide.court] ?? guide.court}
              </a>
            )}
            {guide.city && guide.county && (
              <span class="flex items-center gap-1.5">
                <span class="h-1 w-1 rounded-full bg-white/40"></span>
                {guide.city}, {guide.county}
              </span>
            )}
            <span class="flex items-center gap-1.5">
              <span class="h-1 w-1 rounded-full bg-white/40"></span>
              Updated {guide.lastReviewed ?? 'March 2026'}
            </span>
            <span class="flex items-center gap-1.5">
              <span class="h-1 w-1 rounded-full bg-white/40"></span>
              {readingTime} min read
            </span>
          </div>
        </div>
      </section>

      <!-- Guide content - Modern editorial layout -->
      <section class="py-16 md:py-20">
        <div class="mx-auto max-w-6xl px-6">
          <div class="grid gap-16 lg:grid-cols-12 lg:gap-12">
            <!-- Main content -->
            <article class="guide-article lg:col-span-8">
              
              <!-- Quick Answer - Eye-catching callout -->
              {guide.quickAnswer && (
                <div class="relative overflow-hidden rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/10 via-primary/5 to-transparent p-6 md:p-8">
                  <!-- Decorative circle -->
                  <div class="absolute -right-6 -top-6 h-28 w-28 rounded-full bg-primary/5 md:-right-4 md:-top-4 md:h-32 md:w-32"></div>
                  
                  <!-- Soft glow elements -->
                  <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-primary/10 blur-2xl"></div>
                  <div class="absolute -bottom-4 -left-4 h-20 w-20 rounded-full bg-primary/5 blur-xl"></div>
                  
                  <!-- Icon badge -->
                  <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/15 px-3 py-1">
                    <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wider text-primary">Quick Answer</span>
                  </div>
                  
                  <p class="relative text-base leading-relaxed text-foreground md:text-lg">
                    {guide.quickAnswer}
                  </p>
                </div>
              )}

              <!-- Overview section -->
              <section id="overview" class="guide-section scroll-mt-24">
                <h2>Overview</h2>
                <p class="mt-4 text-muted-foreground">
                  This guide explains the legal process related to this situation in {guide.city ?? site.location.city} and {guide.county ?? site.location.county} courts.
                </p>

                {Array.isArray(guide.takeaways) && guide.takeaways.length > 0 && (
                  <div class="mt-8">
                    <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
                      Key Takeaways
                    </h3>
                    <ul class="space-y-3">
                      {guide.takeaways.map((point) => (
                        <li class="flex items-start gap-3 text-sm leading-relaxed text-muted-foreground">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span>
                          <span>{point}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </section>
              
              <!-- Process Steps - Timeline style -->
              {processSteps.length > 0 && (
                <section id="legal-process" class="guide-section scroll-mt-24">
                  <h2>Step-by-Step Legal Process</h2>
                  <div class="relative mt-8">
                    <!-- Timeline line -->
                    <div class="absolute bottom-0 left-5 top-0 w-px bg-border md:left-6"></div>
                    
                    <div class="space-y-8">
                      {processSteps.map((step, index) => (
                        <div class="group relative flex gap-4 md:gap-6">
                          <!-- Step number -->
                          <div class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-background text-sm font-semibold text-primary ring-4 ring-background transition-transform duration-300 group-hover:scale-105 md:h-12 md:w-12">
                            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 transition-colors duration-300 group-hover:bg-primary/20 md:h-10 md:w-10">
                              {String(index + 1).padStart(2, '0')}
                            </span>
                          </div>
                          
                          <!-- Step content -->
                          <div class="flex-1 pb-2 pt-1">
                            <h3 class="text-base font-semibold text-foreground transition-colors duration-300 group-hover:text-primary md:text-lg">
                              {step.title}
                            </h3>
                            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                              {step.description}
                            </p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </section>
              )}

              <!-- Courts - Simplified cards -->
              {relevantCourts.length > 0 && (
                <section id="courts" class="guide-section scroll-mt-24">
                  <h2>Relevant Courts</h2>
                  <div class="mt-6 space-y-3">
                    {relevantCourts.map((court) => (
                      <a
                        href={court.href ?? `/courts/${court.slug}`}
                        class="group flex items-center justify-between rounded-lg border border-border bg-card p-4 transition-all hover:border-primary/30 hover:bg-secondary/50 md:p-5"
                      >
                        <div class="flex items-center gap-4">
                          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                            <Building2 class="h-5 w-5" />
                          </div>
                          <div>
                            <h3 class="font-medium text-foreground group-hover:text-primary">
                              {court.name}
                            </h3>
                            {court.cardDescription && (
                              <p class="mt-0.5 text-sm text-muted-foreground">
                                {court.cardDescription}
                              </p>
                            )}
                          </div>
                        </div>
                        <ArrowRight class="h-5 w-5 text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-primary" />
                      </a>
                    ))}
                  </div>
                </section>
              )}

              <!-- How a Lawyer Can Help -->
              <section id="lawyer-help" class="guide-section scroll-mt-24">
                <h2>{lawyerHelpHeading}</h2>
                {lawyerHelpIntro && (
                  <p class="mt-4 text-muted-foreground">
                    {lawyerHelpIntro}
                  </p>
                )}
                <ul class="mt-6 space-y-4">
                  {lawyerHelpBullets.map((bullet) => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed text-muted-foreground">
                      <span class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10">
                        <Check class="h-3 w-3 text-primary" />
                      </span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </section>

              <!-- FAQs - Accordion style -->
              {faqs.length > 0 && (
                <section id="faq" class="guide-section scroll-mt-24" aria-labelledby="faq-heading">
                  <h2 id="faq-heading">Frequently Asked Questions</h2>
                  <div class="mt-6 divide-y divide-border" role="list">
                    {faqs.map((faq, index) => (
                      <details class="group py-4 first:pt-0 last:pb-0" role="listitem">
                        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-lg px-3 py-2 -mx-3 text-left font-medium text-foreground transition-all duration-200 hover:bg-secondary/50 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background">
                          <span id={`faq-question-${index}`}>{faq.question}</span>
                          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-secondary text-muted-foreground transition-all duration-300 group-open:rotate-45 group-open:bg-primary group-open:text-primary-foreground" aria-hidden="true">
                            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path d="M12 5v14M5 12h14" />
                            </svg>
                          </span>
                        </summary>
                        <div class="mt-3 pl-3 pr-12 text-sm leading-relaxed text-muted-foreground" aria-labelledby={`faq-question-${index}`}>
                          {faq.answer}
                        </div>
                      </details>
                    ))}
                  </div>
                </section>
              )}

              <!-- Why Choose Local - Enhanced with icons -->
              <section class="guide-section" id="why-choose-local">
                <h2>Why Choose a Local {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea} Lawyer</h2>
                <div class="mt-6 grid gap-4 sm:grid-cols-2">
                  <div class="group relative overflow-hidden rounded-xl border border-border bg-card p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                    <div class="absolute -right-4 -top-4 h-20 w-20 rounded-full bg-primary/5 transition-transform duration-300 group-hover:scale-110"></div>
                    <div class="relative">
                      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary/15">
                        <MapPin class="h-5 w-5" />
                      </div>
                      <h3 class="font-medium text-foreground">Local Court Experience</h3>
                      <p class="mt-1.5 text-sm text-muted-foreground">Proven track record in {guide.county ?? site.location.county} courts with knowledge of local procedures.</p>
                    </div>
                  </div>
                  <div class="group relative overflow-hidden rounded-xl border border-border bg-card p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                    <div class="absolute -right-4 -top-4 h-20 w-20 rounded-full bg-primary/5 transition-transform duration-300 group-hover:scale-110"></div>
                    <div class="relative">
                      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary/15">
                        <Users class="h-5 w-5" />
                      </div>
                      <h3 class="font-medium text-foreground">Prosecutor Relationships</h3>
                      <p class="mt-1.5 text-sm text-muted-foreground">Familiarity with local prosecutors and their typical approaches to cases like yours.</p>
                    </div>
                  </div>
                  <div class="group relative overflow-hidden rounded-xl border border-border bg-card p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                    <div class="absolute -right-4 -top-4 h-20 w-20 rounded-full bg-primary/5 transition-transform duration-300 group-hover:scale-110"></div>
                    <div class="relative">
                      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary/15">
                        <FileText class="h-5 w-5" />
                      </div>
                      <h3 class="font-medium text-foreground">NY Legal Expertise</h3>
                      <p class="mt-1.5 text-sm text-muted-foreground">Deep understanding of New York criminal procedure and state-specific laws.</p>
                    </div>
                  </div>
                  <div class="group relative overflow-hidden rounded-xl border border-border bg-card p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-md">
                    <div class="absolute -right-4 -top-4 h-20 w-20 rounded-full bg-primary/5 transition-transform duration-300 group-hover:scale-110"></div>
                    <div class="relative">
                      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary/15">
                        <Shield class="h-5 w-5" />
                      </div>
                      <h3 class="font-medium text-foreground">Full Case Support</h3>
                      <p class="mt-1.5 text-sm text-muted-foreground">Dedicated representation at every stage from arraignment through resolution.</p>
                    </div>
                  </div>
                </div>
              </section>

              <!-- Sources -->
              {Array.isArray(guide.sources) && guide.sources.length > 0 && (
                <section class="guide-section">
                  <h2>Sources</h2>
                  <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
                    {guide.sources.map((source) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-muted-foreground"></span>
                        {source.url ? (
                          <a
                            href={source.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-primary underline-offset-2 hover:underline"
                          >
                            {source.title ?? source.url}
                          </a>
                        ) : (
                          <span>{source.title}</span>
                        )}
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              <!-- CTA - Clean and prominent -->
              <div class="relative overflow-hidden rounded-xl bg-slate-900 p-8 md:p-10">
                <!-- Decorative elements -->
                <div class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-primary/20"></div>
                <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-primary/10"></div>
                
                <div class="relative">
                  <h2 class="!text-xl !font-semibold !text-white md:!text-2xl">
                    {guide.cta?.headline ?? `Need legal guidance for this situation?`}
                  </h2>
                  <p class="!mt-3 !text-sm !leading-relaxed !text-slate-300 md:!text-base">
                    {guide.cta?.body ??
                      `A lawyer can explain your options, appear with you in local courts, and work to protect your rights. Call ${site.phone} to speak with ${site.firmName}.`}
                  </p>
                  <a
                    href="/contact"
                    class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition-all hover:gap-3 hover:bg-slate-100"
                  >
                    Schedule Consultation
                    <ArrowRight class="h-4 w-4" />
                  </a>
                </div>
              </div>

              <!-- Related Guides - Enhanced -->
              {relatedGuides.length > 0 && (
                <section class="guide-section">
                  <div class="flex items-center justify-between">
                    <h2>Related Guides</h2>
                    <a href="/guides" class="group flex items-center gap-1 text-sm font-medium text-primary transition-colors hover:text-primary/80">
                      View all guides
                      <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                    </a>
                  </div>
                  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
                    {relatedGuides.slice(0, 2).map((related) => (
                      <a 
                        href={`/guides/${related.slug}`}
                        class="group relative overflow-hidden rounded-xl border border-border bg-card p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-lg"
                      >
                        <div class="flex items-start gap-4">
                          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors group-hover:bg-primary/15">
                            <BookOpen class="h-5 w-5" />
                          </div>
                          <div class="min-w-0 flex-1">
                            <h3 class="font-medium text-foreground transition-colors group-hover:text-primary">{related.title}</h3>
                            <p class="mt-1.5 line-clamp-2 text-sm text-muted-foreground">{related.description}</p>
                          </div>
                        </div>
                        <div class="mt-4 flex items-center justify-between text-xs text-muted-foreground">
                          <span>{related.lastReviewed ? `Updated ${related.lastReviewed}` : ''}</span>
                          <span class="flex items-center gap-1 font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
                            Read guide <ArrowRight class="h-3 w-3" />
                          </span>
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              )}
            </article>

            <!-- Sidebar - Cleaner, less boxy -->
            <aside class="space-y-8 lg:sticky lg:top-24 lg:col-span-4 lg:self-start" aria-label="Sidebar">
              
              <!-- Table of Contents - Desktop only -->
              <nav class="hidden rounded-xl border border-border bg-card p-5 lg:block" aria-label="Table of Contents">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                  On This Page
                </h3>
                <ul class="mt-4 space-y-2">
                  {tocItems.map((item) => (
                    <li>
                      <a 
                        href={`#${item.id}`}
                        class="toc-link group flex items-center gap-2 rounded-md px-2 py-1.5 text-sm text-muted-foreground transition-all hover:bg-secondary hover:text-foreground"
                        data-section={item.id}
                      >
                        <span class="h-1 w-1 rounded-full bg-border transition-all group-hover:bg-primary"></span>
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
              
              <!-- Primary CTA Card -->
              <div class="rounded-xl bg-secondary/70 p-6">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                  Need Help?
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  If you've been arrested for DUI or another criminal charge in {site.location.city} or anywhere in {site.location.county}, speaking with a local defense attorney early can help protect your record and driving privileges.
                </p>
                <a
                  href="/contact"
                  class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
                >
                  Schedule Consultation
                  <ArrowRight class="h-4 w-4" />
                </a>
              </div>

              <!-- Local Courts - Simplified list -->
              <nav aria-label="Local Courts">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                  Local Courts
                </h3>
                <div class="mt-4 space-y-2">
                  <a href="/courts/jamestown-city-court" class="flex items-center gap-3 rounded-lg p-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary">
                    <Building2 class="h-4 w-4 text-primary" aria-hidden="true" />
                    Jamestown City Court
                  </a>
                  <a href="/courts/dunkirk-city-court" class="flex items-center gap-3 rounded-lg p-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary">
                    <Building2 class="h-4 w-4 text-primary" aria-hidden="true" />
                    Dunkirk City Court
                  </a>
                  <a href="/courts/chautauqua-county-court" class="flex items-center gap-3 rounded-lg p-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary">
                    <Building2 class="h-4 w-4 text-primary" aria-hidden="true" />
                    Chautauqua County Court
                  </a>
                </div>
              </nav>

              <!-- Local Resources -->
              {localResources.length > 0 && (
                <div>
                  <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                    Local Resources
                  </h3>
                  <div class="mt-4 space-y-4">
                    {localResources.map((resource) => (
                      <div class="text-sm">
                        <div class="flex items-start gap-2">
                          <Building2 class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
                          <div class="min-w-0">
                            {resource.href ? (
                              <a
                                href={resource.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="font-medium text-foreground hover:text-primary"
                              >
                                {resource.label}
                              </a>
                            ) : (
                              <p class="font-medium text-foreground">{resource.label}</p>
                            )}
                            {resource.description && (
                              <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
                                {resource.description}
                              </p>
                            )}
                            {Array.isArray(resource.details) && resource.details.length > 0 && (
                              <ul class="mt-2 space-y-1 text-xs leading-relaxed text-muted-foreground">
                                {resource.details.map((detail) => (
                                  <li>{detail}</li>
                                ))}
                              </ul>
                            )}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </aside>
          </div>
        </div>
      </section>

    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  /* Smooth scrolling for the page */
  html {
    scroll-behavior: smooth;
  }

  /* Respect user preference for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    details[open] > summary ~ * {
      animation: none;
    }
  }

  .guide-article {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .guide-section h2 {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  @media (min-width: 768px) {
    .guide-section h2 {
      font-size: 1.5rem;
    }
  }

  .guide-section p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted-foreground);
  }

  /* Smooth accordion animation */
  details[open] > summary ~ * {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Remove default marker */
  summary::-webkit-details-marker {
    display: none;
  }

  /* Enhanced focus states for keyboard navigation */
  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* TOC active state */
  .toc-link.active {
    background-color: var(--color-secondary);
    color: var(--color-foreground);
  }
  .toc-link.active span {
    background-color: var(--color-primary);
    width: 0.375rem;
    height: 0.375rem;
  }

  /* Micro-interaction hover effects */
  .guide-section {
    transition: opacity 0.2s ease;
  }
</style>

<script>
  // Intersection Observer for TOC active state
  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('.guide-section[id], #overview');
    const tocLinks = document.querySelectorAll('.toc-link');
    
    if (sections.length === 0 || tocLinks.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            tocLinks.forEach((link) => {
              const linkSection = link.getAttribute('data-section');
              if (linkSection === id) {
                link.classList.add('active');
              } else {
                link.classList.remove('active');
              }
            });
          }
        });
      },
      {
        rootMargin: '-20% 0% -70% 0%',
        threshold: 0,
      }
    );

    sections.forEach((section) => {
      if (section.id) {
        observer.observe(section);
      }
    });
  });
</script>
