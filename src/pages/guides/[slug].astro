---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import { guides } from '@/src/data/guides';
import { courts } from '@/src/data/courts';
import { site } from '@/src/config/site';
import { practiceLabels, courtLabels } from '@/src/config/labels';
import Building2 from '@lucide/astro/icons/building-2';
import Check from '@lucide/astro/icons/check';
import GuideCard from '@/src/components/GuideCard.astro';
import type { Guide } from '@/src/types/content';

export async function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props as { guide: Guide };

const relatedGuides = guides.filter(
  (g) => g.practiceArea === guide.practiceArea && g.slug !== guide.slug
);

const relevantCourts = Array.isArray(guide.courts)
  ? guide.courts
      .map((slug) => courts.find((court) => court.slug === slug))
      .filter((court): court is (typeof courts)[number] => Boolean(court))
  : [];

const processSteps = Array.isArray(guide.processSteps) ? guide.processSteps : [];
const faqs = Array.isArray(guide.faqs) ? guide.faqs : [];
const localResources = Array.isArray(guide.localResources) ? guide.localResources : [];
const lawyerHelp = guide.lawyerHelp;
const hasCustomLawyerHelp =
  Boolean(lawyerHelp && Array.isArray(lawyerHelp.bullets) && lawyerHelp.bullets.length > 0);
const defaultLawyerHelpIntro =
  'A criminal defense lawyer can guide you through each stage of the case and work to protect your rights and future.';
const defaultLawyerHelpBullets = [
  'Review the legality of the traffic stop, arrest, and any searches.',
  'Challenge chemical test results and other key pieces of evidence.',
  'Negotiate with prosecutors for reduced charges or alternative sentencing.',
  'Represent you in court hearings, pre-trial motions, and trial if necessary.',
];
const lawyerHelpHeading = lawyerHelp?.heading ?? 'How a Lawyer Can Help';
/** Custom guides: omit paragraph when `intro` is unset. Default guides: criminal-defense intro. */
const lawyerHelpIntro = hasCustomLawyerHelp ? lawyerHelp!.intro : defaultLawyerHelpIntro;
const lawyerHelpBullets = hasCustomLawyerHelp ? lawyerHelp!.bullets : defaultLawyerHelpBullets;
---

<BaseLayout
  title={`${guide.title} | ${site.firmName}`}
  description={guide.description}
>
  <div class="flex min-h-screen flex-col">
    <SiteHeader />
    <main>
      <!-- Hero -->
      <section class="relative isolate overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 py-20 md:py-28">
        <div aria-hidden="true" class="absolute -top-40 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-gradient-to-br from-blue-500/30 via-indigo-500/20 to-transparent blur-3xl" />
        <div aria-hidden="true" class="absolute -bottom-20 right-0 -z-10 h-[350px] w-[350px] rounded-full bg-gradient-to-tl from-blue-600/20 via-cyan-500/10 to-transparent blur-3xl" />
        <div aria-hidden="true" class="absolute inset-0 -z-10 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:72px_72px]" />

        <div class="relative mx-auto max-w-6xl px-6">
          <nav class="mb-5 flex items-center gap-2 text-sm text-slate-400">
            <a href="/" class="transition-colors hover:text-white">Home</a>
            <span>/</span>
            <a href="/guides" class="transition-colors hover:text-white">Guides</a>
            <span>/</span>
            <span class="text-slate-300">{guide.title}</span>
          </nav>

          <h1 class="max-w-3xl text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">
            {guide.title}
          </h1>
          <p class="mt-4 max-w-2xl text-pretty text-base leading-relaxed text-slate-300 md:text-lg">
            {guide.description}
          </p>
          <div class="mt-5 flex flex-wrap items-center gap-4 text-sm text-slate-400">
            <span>
              Practice Area:{' '}
              <a
                href={`/practice/${guide.practiceArea}`}
                class="font-medium text-blue-400 hover:text-blue-300 hover:underline"
              >
                {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea}
              </a>
            </span>
            {guide.court && (
              <span>
                · Court:{' '}
                <a
                  href={`/courts/${guide.court}`}
                  class="font-medium text-blue-400 hover:text-blue-300 hover:underline"
                >
                  {courtLabels[guide.court] ?? guide.court}
                </a>
              </span>
            )}
            {guide.city && guide.county && (
              <span>· {guide.city}, {guide.county}</span>
            )}
            <span>· Last reviewed: {guide.lastReviewed ?? 'March 2026'}</span>
          </div>
        </div>
      </section>

      <!-- Guide content -->
      <section class="bg-background py-20 md:py-24">
        <div class="mx-auto max-w-6xl px-6">
          <div class="grid gap-10 lg:grid-cols-10">
            <article class="guide-article lg:col-span-7">
              {guide.quickAnswer && (
                <div class="rounded-2xl border border-border bg-card/60 p-6 text-sm text-muted-foreground">
                  <p>
                    <span class="font-semibold text-foreground">Quick Answer:</span>{' '}
                    {guide.quickAnswer}
                  </p>
                </div>
              )}
            <section id="overview" class="guide-section scroll-mt-24">
              <h2>Overview</h2>
              <p class="mt-4">
                This guide explains the legal process related to this situation in {guide.city ?? site.location.city} and {guide.county ?? site.location.county} courts.
              </p>

              {Array.isArray(guide.takeaways) && guide.takeaways.length > 0 && (
                <div class="mt-6 rounded-2xl border border-border bg-card/60 p-6">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">
                    Key Takeaways
                  </h3>
                  <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-muted-foreground">
                    {guide.takeaways.map((point) => (
                      <li>{point}</li>
                    ))}
                  </ul>
                </div>
              )}
            </section>
            
            {processSteps.length > 0 && (
              <section id="legal-process" class="guide-section scroll-mt-24">
                <h2>Step-by-Step Legal Process</h2>
                <div class="mt-6 space-y-4">
                  {processSteps.map((step, index) => (
                    <div class="flex gap-4 rounded-2xl border border-border bg-card p-6">
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 font-semibold text-primary">
                        {String(index + 1).padStart(2, '0')}
                      </div>
                      <div class="flex-1">
                        <h3 class="text-base font-semibold text-foreground">
                          {step.title}
                        </h3>
                        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                          {step.description}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            )}

            {relevantCourts.length > 0 && (
              <section id="courts" class="guide-section scroll-mt-24">
                <h2>Relevant Courts</h2>
                <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
                  {relevantCourts.map((court) => (
                    <a
                      href={court.href ?? `/courts/${court.slug}`}
                      class="group block rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-primary/50 hover:shadow-lg"
                    >
                      <div class="flex items-start gap-4">
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                          <Building2 class="h-6 w-6" />
                        </div>
                        <div class="flex-1">
                          <h3 class="text-base font-semibold text-foreground group-hover:text-primary">
                            {court.name}
                          </h3>
                          {court.cardDescription && (
                            <p class="mt-2 text-sm text-muted-foreground">
                              {court.cardDescription}
                            </p>
                          )}
                          <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-primary">
                            View Court Information
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </section>
            )}

            <section id="lawyer-help" class="guide-section scroll-mt-24">
              <h2>{lawyerHelpHeading}</h2>
              {lawyerHelpIntro && (
                <p class="mt-4">
                  {lawyerHelpIntro}
                </p>
              )}
              <ul class="mt-6 space-y-3 text-sm text-muted-foreground">
                {lawyerHelpBullets.map((bullet) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-primary" />
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </section>

            {faqs.length > 0 && (
              <section id="faq" class="guide-section scroll-mt-24">
                <h2>Frequently Asked Questions</h2>
                <div class="mt-6 space-y-3">
                  {faqs.map((faq) => (
                    <details class="group rounded-2xl border border-border bg-card px-6 py-4">
                      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-sm font-semibold text-foreground">
                        <span>{faq.question}</span>
                        <span class="shrink-0 transition-transform group-open:rotate-90">›</span>
                      </summary>
                      <div class="mt-3 border-t border-border pt-4 text-sm leading-relaxed text-muted-foreground">
                        {faq.answer}
                      </div>
                    </details>
                  ))}
                </div>
              </section>
            )}

            <section class="guide-section" id="why-choose-local">
              <h2>Why Choose a Local {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea} Lawyer</h2>
              <ul class="mt-6 space-y-3" role="list">
                <li class="flex items-start gap-3 rounded-xl border border-border bg-card px-5 py-4">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                    <Check class="h-3.5 w-3.5" />
                  </span>
                  <span class="text-sm text-muted-foreground">Experience in local courts</span>
                </li>
                <li class="flex items-start gap-3 rounded-xl border border-border bg-card px-5 py-4">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                    <Check class="h-3.5 w-3.5" />
                  </span>
                  <span class="text-sm text-muted-foreground">Familiarity with local prosecutors</span>
                </li>
                <li class="flex items-start gap-3 rounded-xl border border-border bg-card px-5 py-4">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                    <Check class="h-3.5 w-3.5" />
                  </span>
                  <span class="text-sm text-muted-foreground">Understanding of New York criminal procedure</span>
                </li>
                <li class="flex items-start gap-3 rounded-xl border border-border bg-card px-5 py-4">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary" aria-hidden="true">
                    <Check class="h-3.5 w-3.5" />
                  </span>
                  <span class="text-sm text-muted-foreground">Representation at every stage of the case</span>
                </li>
              </ul>
            </section>

            {Array.isArray(guide.sources) && guide.sources.length > 0 && (
              <section class="guide-section">
                <h2>Sources</h2>
                <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-muted-foreground">
                  {guide.sources.map((source) => (
                    <li>
                      {source.url ? (
                        <a
                          href={source.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:underline"
                        >
                          {source.title ?? source.url}
                        </a>
                      ) : (
                        <span>{source.title}</span>
                      )}
                    </li>
                  ))}
                </ul>
              </section>
            )}

            <section class="guide-section">
              <div class="rounded-2xl border border-primary/20 bg-primary/5 p-8">
                <h2 class="text-lg font-semibold text-foreground">
                  {guide.cta?.headline ?? `Need legal guidance for this situation?`}
                </h2>
                <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
                  {guide.cta?.body ??
                    `A lawyer can explain your options, appear with you in local courts, and work to protect your rights. Call ${site.phone} to speak with ${site.firmName}.`}
                </p>
                <a
                  href="/contact"
                  class="mt-6 inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
                >
                  Schedule Consultation
                </a>
              </div>
            </section>

            {relatedGuides.length > 0 && (
              <section class="guide-section">
                <h2>Other Guides for {practiceLabels[guide.practiceArea as keyof typeof practiceLabels] ?? guide.practiceArea}</h2>
                <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
                  {relatedGuides.slice(0, 3).map((related) => (
                    <GuideCard guide={related} />
                  ))}
                </div>
              </section>
            )}
          </article>

          <aside class="mt-10 space-y-6 self-start lg:mt-0 lg:sticky lg:top-24 lg:col-span-3">
            <div class="rounded-2xl border border-border bg-card p-6 text-sm shadow-sm">
              <h2 class="font-semibold uppercase tracking-wide text-foreground">
                Charged with a DUI?
              </h2>
              <p class="mt-3 text-muted-foreground">
                If you've been arrested for DUI or another criminal charge in {site.location.city} or anywhere in {site.location.county}, speaking with a local defense attorney early can help protect your record and driving privileges.
              </p>
              <a
                href="/contact"
                class="mt-5 inline-flex w-full items-center justify-center rounded-full bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
              >
                Schedule Consultation
              </a>
            </div>

            <div class="rounded-2xl border border-border bg-card p-6 text-sm shadow-sm">
              <h2 class="font-semibold uppercase tracking-wide text-foreground">
                Local Courts
              </h2>
              <ul class="mt-3 space-y-2">
                <li class="flex items-center gap-2 text-muted-foreground">
                  <Building2 class="h-4 w-4 text-primary" />
                  <a href="/courts/jamestown-city-court" class="text-primary hover:underline">
                    Jamestown City Court
                  </a>
                </li>
                <li class="flex items-center gap-2 text-muted-foreground">
                  <Building2 class="h-4 w-4 text-primary" />
                  <a href="/courts/dunkirk-city-court" class="text-primary hover:underline">
                    Dunkirk City Court
                  </a>
                </li>
                <li class="flex items-center gap-2 text-muted-foreground">
                  <Building2 class="h-4 w-4 text-primary" />
                  <a href="/courts/chautauqua-county-court" class="text-primary hover:underline">
                    Chautauqua County Court
                  </a>
                </li>
              </ul>
            </div>

            {localResources.length > 0 && (
              <div class="rounded-2xl border border-border bg-card p-6 text-sm shadow-sm">
                <h2 class="font-semibold uppercase tracking-wide text-foreground">
                  Local Resources
                </h2>
                <ul class="mt-3 space-y-2">
                  {localResources.map((resource) => (
                    <li class="rounded-xl border border-border bg-background p-3 text-muted-foreground">
                      <div class="flex items-start gap-2">
                        <Building2 class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
                        <div class="min-w-0">
                          {resource.href ? (
                            <a
                              href={resource.href}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="font-medium text-primary hover:underline"
                            >
                              {resource.label}
                            </a>
                          ) : (
                            <p class="font-medium text-foreground">{resource.label}</p>
                          )}
                          {resource.description && (
                            <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
                              {resource.description}
                            </p>
                          )}
                          {Array.isArray(resource.details) && resource.details.length > 0 && (
                            <ul class="mt-2 list-disc space-y-1 pl-4 text-xs leading-relaxed text-muted-foreground">
                              {resource.details.map((detail) => (
                                <li>{detail}</li>
                              ))}
                            </ul>
                          )}
                        </div>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </aside>
        </div>
      </section>

    </main>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .guide-article {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .guide-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin: 0;
    line-height: 1.3;
  }

  .guide-section p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-muted-foreground);
  }
</style>
