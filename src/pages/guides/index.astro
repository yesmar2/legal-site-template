---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '@/src/components/site-header.astro';
import SiteFooter from '@/src/components/site-footer.astro';
import PageCTA from '@/src/components/layout/PageCTA.astro';
import { guides } from '@/src/data/guides';
import { site } from '@/src/config/site';
import { courts } from '@/src/data/courts';
import BookOpen from '@lucide/astro/icons/book-open';
import ArrowRight from '@lucide/astro/icons/arrow-right';

const pageTitle = `Legal Guides | ${site.firmName}`;
const pageDescription = `Practical legal guides from ${site.firmName} to help people throughout ${site.location.county} understand common legal issues and local court processes.`;

const practiceLabels: Record<string, string> = {
  "criminal-defense": "Criminal Defense",
  "family-law": "Family Law",
  "personal-injury": "Personal Injury",
  "real-estate-law": "Real Estate Law",
  "elder-law": "Elder Law",
};

const getPrimaryCourt = (guide: (typeof guides)[number]) => {
  const slug = Array.isArray(guide.courts) && guide.courts.length > 0 ? guide.courts[0] : undefined;
  return slug ? courts.find((court) => court.slug === slug) : undefined;
};

// Group guides by practice area
const guidesByPractice = guides.reduce((acc, guide) => {
  const area = guide.practiceArea;
  if (!acc[area]) acc[area] = [];
  acc[area].push(guide);
  return acc;
}, {} as Record<string, typeof guides>);
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <div class="flex min-h-screen flex-col bg-background">
    <SiteHeader />
    <main>
      <!-- Hero Section - Dark with legal themed CSS background -->
      <section class="relative isolate overflow-hidden bg-gradient-to-r from-slate-900 via-blue-950 to-blue-900 pb-16 pt-8 md:pb-20 md:pt-12">
        <!-- SVG decorative elements -->
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
          <!-- Abstract flowing curves -->
          <svg class="absolute inset-0 h-full w-full" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="curve-gradient-index" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="rgba(255,255,255,0.03)" />
                <stop offset="100%" stop-color="rgba(255,255,255,0.08)" />
              </linearGradient>
            </defs>
            <!-- Flowing curves -->
            <path d="M-100,200 Q200,100 400,200 T800,200 T1200,200 T1600,200" fill="none" stroke="url(#curve-gradient-index)" stroke-width="1" />
            <path d="M-100,250 Q200,150 400,250 T800,250 T1200,250 T1600,250" fill="none" stroke="url(#curve-gradient-index)" stroke-width="1" />
            <path d="M-100,300 Q200,200 400,300 T800,300 T1200,300 T1600,300" fill="none" stroke="url(#curve-gradient-index)" stroke-width="1" />
            <path d="M-100,350 Q200,250 400,350 T800,350 T1200,350 T1600,350" fill="none" stroke="url(#curve-gradient-index)" stroke-width="1" />
          </svg>
          
          <!-- Scales of justice icon -->
          <svg class="absolute right-8 top-1/2 h-64 w-64 -translate-y-1/2 text-white/[0.06] md:right-16 md:h-80 md:w-80 lg:right-24 lg:h-96 lg:w-96" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L12 22" stroke-linecap="round" />
            <path d="M2 6L12 3L22 6" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M2 6L2 8C2 10 4 12 7 12C10 12 12 10 12 8L12 6" stroke-linecap="round" />
            <path d="M12 6L12 8C12 10 14 12 17 12C20 12 22 10 22 8L22 6" stroke-linecap="round" />
            <circle cx="7" cy="9" r="4" />
            <circle cx="17" cy="9" r="4" />
          </svg>
          
          <!-- Soft glow accents -->
          <div class="absolute -left-32 top-1/4 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl"></div>
          <div class="absolute -right-32 bottom-1/4 h-80 w-80 rounded-full bg-blue-400/10 blur-3xl"></div>
        </div>
        
        <div class="relative mx-auto max-w-6xl px-6">
          <div class="inline-flex items-center gap-2 rounded-full border border-sky-300/30 bg-sky-400/20 px-3 py-1 text-xs font-medium text-sky-100 backdrop-blur-sm">
            <BookOpen class="h-3.5 w-3.5" />
            Resources & Information
          </div>
          
          <h1 class="mt-6 max-w-3xl text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl md:text-6xl">
            Legal Guides
          </h1>
          
          <p class="mt-6 max-w-2xl text-base leading-relaxed text-sky-50/90 md:text-lg">
            Our legal guides explain common legal situations in {site.location.city} and throughout {site.location.county}, {site.address.state}. These resources cover topics such as DUI arrests, criminal court procedures, and family law matters, including what to expect in local courts like{' '}
            <a href="/courts/jamestown-city-court" class="font-medium text-sky-200 underline underline-offset-2 hover:text-white">
              Jamestown City Court
            </a>
            {' '}and{' '}
            <a href="/courts/chautauqua-county-court" class="font-medium text-sky-200 underline underline-offset-2 hover:text-white">
              Chautauqua County Court
            </a>.
          </p>
        </div>
      </section>

      <!-- Guides Grid - Modern flowing layout -->
      <section class="py-16 md:py-20">
        <div class="mx-auto max-w-6xl px-6">
          {Object.entries(guidesByPractice).map(([practiceArea, practiceGuides]) => (
            <div class="mb-16 last:mb-0">
              <div class="mb-6 flex items-center gap-3">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">
                  {practiceLabels[practiceArea] ?? practiceArea}
                </h2>
                <div class="h-px flex-1 bg-border"></div>
              </div>
              
              <div class="grid gap-4 sm:grid-cols-2">
                {practiceGuides.map((guide) => (
                  <a 
                    href={`/guides/${guide.slug}`}
                    class="group relative flex flex-col rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:bg-secondary/30"
                  >
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                        <BookOpen class="h-5 w-5 text-primary" />
                      </div>
                      <ArrowRight class="h-5 w-5 text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-primary" />
                    </div>
                    
                    <h3 class="mt-4 text-lg font-medium text-foreground group-hover:text-primary">
                      {guide.title}
                    </h3>
                    
                    <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">
                      {guide.description}
                    </p>
                    
                    <div class="mt-4 flex items-center gap-4 text-xs text-muted-foreground">
                      {guide.lastReviewed && (
                        <span>Updated {guide.lastReviewed}</span>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <PageCTA
        title="Questions About Your Situation?"
        description="Speak with an attorney today about your case and the legal process."
      />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
